#!/usr/bin/env python3
"""Open a Moss-owned Kanban incident for Jen environment/runtime failures."""
from __future__ import annotations
import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone

DEFAULT_KANBAN_HOME = "/mnt/hermes-shared/kanban/the-ai-crowd"
BOARD = "incidents"
ASSIGNEE = "incidents"


def hermes_bin() -> str:
    for candidate in ("/opt/hermes/.venv/bin/hermes", shutil.which("hermes")):
        if candidate and os.path.exists(candidate):
            return candidate
    raise SystemExit("ERROR: hermes CLI not found")


def run(cmd: list[str], env: dict[str, str], check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, env=env, check=check)


def ensure_board(hermes: str, env: dict[str, str]) -> None:
    listed = run([hermes, "kanban", "boards", "list", "--json"], env, check=True)
    boards = json.loads(listed.stdout or "[]")
    if not any(b.get("slug") == BOARD for b in boards):
        run([
            hermes, "kanban", "boards", "create", BOARD,
            "--name", "Incidents",
            "--description", "Cross-agent technical incidents owned by Moss",
        ], env, check=True)
    run([hermes, "kanban", "--board", BOARD, "init"], env, check=True)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Open a Moss-owned Kanban incident when Jen has a technical environment/runtime failure."
    )
    parser.add_argument("summary", help="Short incident summary")
    parser.add_argument("--severity", default="medium", choices=["low", "medium", "high", "critical"], help="Incident severity")
    parser.add_argument("--evidence", action="append", default=[], help="Evidence reference or brief observation; repeatable")
    parser.add_argument("--requested-outcome", default="Moss diagnoses, remediates or blocks with the next required operator decision, then reports the result back to Jen/Rodolfo.")
    parser.add_argument("--idempotency-key", default="", help="Optional Kanban idempotency key")
    parser.add_argument("--dry-run", action="store_true", help="Print planned Kanban payload without creating a card")
    args = parser.parse_args()

    summary = args.summary.strip()
    if not summary:
        print("ERROR: summary is required", file=sys.stderr)
        return 2

    details = ""
    if not sys.stdin.isatty():
        details = sys.stdin.read().strip()

    now = datetime.now(timezone.utc).isoformat()
    env = os.environ.copy()
    env.setdefault("HERMES_KANBAN_HOME", DEFAULT_KANBAN_HOME)

    title = f"incident: Jen environment - {summary}"
    evidence_lines = [f"- {item}" for item in (args.evidence or [])]
    if details:
        evidence_lines.append(details)
    if not evidence_lines:
        evidence_lines.append("- no additional evidence supplied")

    body = "\n".join([
        "# Jen environment incident",
        "",
        f"opened_at: {now}",
        "reporter: jen",
        "affected_agent: jen",
        "owner: moss",
        "decision_owner: moss",
        "executor: moss",
        "private_data_level: private",
        f"severity: {args.severity}",
        "category: technical-environment",
        "",
        "## Boundary",
        "Jen is not responsible for diagnosing or repairing her own runtime, container, credentials, integrations, gateway, or host environment. This card is a Moss-owned technical incident.",
        "",
        "## Summary",
        summary,
        "",
        "## Evidence",
        *evidence_lines,
        "",
        "## Requested outcome",
        args.requested_outcome,
        "",
        "## Return path",
        "Moss updates/blocks/completes this Kanban card and reports the incident id plus current status back to Jen/Rodolfo. Productivity decisions remain Jen-owned; technical repair remains Moss-owned.",
    ])

    payload = {
        "kanban_home": env["HERMES_KANBAN_HOME"],
        "board": BOARD,
        "title": title,
        "assignee": ASSIGNEE,
        "created_by": "jen",
        "severity": args.severity,
        "body": body,
        "idempotency_key": args.idempotency_key or None,
    }

    if args.dry_run:
        print(json.dumps({"dry_run": True, "payload": payload}, indent=2, ensure_ascii=False))
        return 0

    hermes = hermes_bin()
    ensure_board(hermes, env)
    cmd = [
        hermes, "kanban", "--board", BOARD, "create", title,
        "--body", body,
        "--assignee", ASSIGNEE,
        "--created-by", "jen",
        "--priority", {"low": "10", "medium": "30", "high": "60", "critical": "90"}[args.severity],
        "--json",
    ]
    if args.idempotency_key:
        cmd.extend(["--idempotency-key", args.idempotency_key])
    result = run(cmd, env, check=True)
    print(result.stdout.strip())
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
