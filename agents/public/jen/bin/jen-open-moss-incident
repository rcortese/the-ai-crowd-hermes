#!/usr/bin/env python3
"""Compatibility shim for Jen technical incidents using the canonical handoff wrapper."""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

WRAPPER_PATH = Path(__file__).resolve().with_name("jen-handoff")
SEVERITY_TO_FAILURE_CLASS = {
    "low": "runtime_failure",
    "medium": "runtime_failure",
    "high": "integration_failure",
    "critical": "container_failure",
}


def build_context(*, severity: str, requested_outcome: str, evidence: list[str], details: str) -> str:
    lines = [
        "Jen runtime/environment technical incident.",
        f"severity: {severity}",
        "requested_outcome:",
        requested_outcome,
        "evidence:",
    ]
    if evidence:
        lines.extend(f"- {item}" for item in evidence)
    else:
        lines.append("- no additional evidence supplied")
    if details:
        lines.extend(["details:", details])
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Open a canonical Moss-bound incident handoff when Jen has a technical environment/runtime failure."
    )
    parser.add_argument("summary", help="Short incident summary")
    parser.add_argument("--severity", default="medium", choices=["low", "medium", "high", "critical"], help="Incident severity")
    parser.add_argument("--failure-class", choices=["runtime_failure", "auth_failure", "integration_failure", "network_failure", "container_failure", "gateway_failure", "provider_failure", "policy_block", "root_drift", "delivery_failure", "unknown"], help="Explicit canonical failure class override")
    parser.add_argument("--evidence", action="append", default=[], help="Evidence reference or brief observation; repeatable")
    parser.add_argument("--artifact-ref", action="append", default=[], help="Canonical artifact-ref key=value payload; repeatable")
    parser.add_argument("--requested-outcome", default="Moss diagnoses the technical failure, remediates or blocks with the next required operator decision, then returns status to Jen/Rodolfo.")
    parser.add_argument("--idempotency-key", default="", help="Optional canonical idempotency key")
    parser.add_argument("--root", default="/mnt/hermes-shared/handoffs", help="Canonical handoff root")
    parser.add_argument("--allow-test-root", action="store_true", help="Allow tmp roots for tests")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--dry-run", action="store_true", help="Print the canonical handoff payload without writing it")
    mode.add_argument("--write", action="store_true", help="Write the canonical handoff to the validated root")
    mode.add_argument("--emit", action="store_true", help="Alias for --write")
    args = parser.parse_args()

    summary = args.summary.strip()
    if not summary:
        print("ERROR: summary is required", file=sys.stderr)
        return 2

    details = ""
    if not sys.stdin.isatty():
        details = sys.stdin.read().strip()

    failure_class = args.failure_class or SEVERITY_TO_FAILURE_CLASS[args.severity]
    idempotency_key = args.idempotency_key or f"jen-open-moss-incident:{summary.lower().replace(' ', '-')}:{failure_class}"
    context = build_context(
        severity=args.severity,
        requested_outcome=args.requested_outcome,
        evidence=args.evidence,
        details=details,
    )

    cmd = [
        sys.executable,
        str(WRAPPER_PATH),
        "emit",
        "--target",
        "moss",
        "--owner-domain",
        "technical-ops",
        "--handoff-type",
        "incident",
        "--failure-class",
        failure_class,
        "--summary",
        summary,
        "--objective",
        "Create a sanitized Moss-owned technical incident handoff and preserve Jen as the return path.",
        "--context",
        context,
        "--idempotency-key",
        idempotency_key,
        "--root",
        args.root,
        "--source-runtime",
        "jen-compatibility-shim",
        "--source-host",
        "the-ai-crowd-jen-1",
    ]
    if args.allow_test_root:
        cmd.append("--allow-test-root")
    for item in args.artifact_ref:
        cmd.extend(["--artifact-ref", item])

    if args.dry_run:
        cmd.append("--dry-run")
    elif args.write or args.emit:
        cmd.append("--write")
    else:
        cmd.append("--write")

    result = subprocess.run(cmd, text=True, capture_output=True)
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        if result.stdout:
            sys.stdout.write(result.stdout)
        return result.returncode

    payload = json.loads(result.stdout)
    payload["source"]["wrapper"] = "jen-open-moss-incident"
    print(json.dumps(payload, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
