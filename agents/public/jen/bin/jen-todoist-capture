#!/usr/bin/env bash
set -euo pipefail

workspace_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
runtime="$workspace_root/bin/jen-task-runtime"

content=""
due=""

while (($#)); do
  case "$1" in
    --content)
      content="${2:-}"
      shift 2
      ;;
    --due)
      due="${2:-}"
      shift 2
      ;;
    --help|-h)
      cat <<'USAGE'
Usage:
  jen-todoist-capture --content "task text" [--due "tomorrow"]
USAGE
      exit 0
      ;;
    *)
      if [[ -z "$content" ]]; then
        content="$1"
        shift
      else
        printf 'unexpected argument: %s\n' "$1" >&2
        exit 2
      fi
      ;;
  esac
done

if [[ -z "$content" ]]; then
  "$runtime" capture-task
else
  if [[ -n "$due" ]]; then
    "$runtime" capture-task --content "$content" --due "$due"
  else
    "$runtime" capture-task --content "$content"
  fi
fi
