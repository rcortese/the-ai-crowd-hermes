#!/usr/bin/env bash
set -euo pipefail

CONTRACT_VERSION="jen-todoist-interaction-loop.v1"
WORKSPACE_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
TASK_RUNTIME="${JEN_TODOIST_INTERACTION_LOOP_TASK_RUNTIME:-$WORKSPACE_ROOT/bin/jen-task-runtime}"
DUE_SEMANTICS="${JEN_TODOIST_INTERACTION_LOOP_DUE_SEMANTICS:-$WORKSPACE_ROOT/bin/jen-todoist-due-semantics}"
CAPTURE_WRAPPER="${JEN_TODOIST_INTERACTION_LOOP_CAPTURE_WRAPPER:-$WORKSPACE_ROOT/bin/jen-todoist-capture}"
# shellcheck source=../lib/jen-envelope-emit.sh
source "$WORKSPACE_ROOT/lib/jen-envelope-emit.sh"

now_utc() {
  jen_now_utc
}

json_out() {
  jen_json_out "$1"
}

emit_failed() {
  local failure_class="$1"
  local checked_at detail_json extra_json handoff_id
  checked_at="$(now_utc)"
  handoff_id="$(jen_new_handoff_id "jen-todoist-interaction-loop")"
  detail_json='{"wrapper_name":"jen-todoist-interaction-loop","mutation_attempted":false,"mutation_state":"unknown","safe_summary":"The Todoist wrapper path is not working correctly right now, so I am handing this to Moss."}'
  extra_json="$(jq -nc \
    --arg checked_at "$checked_at" \
    --argjson complete false \
    --arg failure_class "$failure_class" \
    '{checked_at:$checked_at,mode:"canonical_capture",failures:[{source:"loop",failure_class:$failure_class}],complete:$complete}')"
  json_out "$(jen_emit_envelope "$CONTRACT_VERSION" failed failed technical_failure stop_and_handoff_to_moss "The Todoist wrapper path isn't working correctly right now, so I'm handing this to Moss." "$handoff_id" "$detail_json" "$extra_json")"
  exit 1
}

valid_date_ymd() {
  [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && [[ "$(date -d "$1" +%F 2>/dev/null || true)" == "$1" ]]
}

run_runtime_json() {
  local output_file="$1"
  shift
  set +e
  "$TASK_RUNTIME" "$@" >"$output_file" 2>/dev/null
  local status=$?
  set -e
  return "$status"
}

run_due_semantics_json() {
  local output_file="$1"
  shift
  set +e
  "$DUE_SEMANTICS" "$@" >"$output_file" 2>/dev/null
  local status=$?
  set -e
  return "$status"
}

run_capture_json() {
  local output_file="$1"
  shift
  set +e
  "$CAPTURE_WRAPPER" "$@" >"$output_file" 2>/dev/null
  local status=$?
  set -e
  return "$status"
}

wrap_runtime_result() {
  local source="$1"
  local exit_status="$2"
  local output_file="$3"
  if [[ "$exit_status" == "0" ]] && jq empty "$output_file" >/dev/null 2>&1; then
    local runtime_status runtime_source
    runtime_status="$(jq -r '.status // empty' "$output_file")"
    runtime_source="$(jq -r '.source // empty' "$output_file")"
    if [[ "$runtime_status" == "ok" ]]; then
      jq -nc --arg source "$source" --slurpfile output "$output_file" '{status:"ok",source:$source,output:$output[0]}'
    else
      jq -nc \
        --arg source "$source" \
        --arg runtime_status "${runtime_status:-unknown}" \
        --arg runtime_source "${runtime_source:-unknown}" \
        --slurpfile output "$output_file" \
        '{status:"degraded",source:$source,runtime_status:$runtime_status,runtime_source:$runtime_source,output:$output[0]}'
    fi
    return 0
  fi

  local failure_class
  failure_class="$(jq -r '.failure_class // empty' "$output_file" 2>/dev/null || true)"
  [[ -n "$failure_class" ]] || failure_class="runtime_failure"
  jq -nc --arg source "$source" --arg failure_class "$failure_class" --argjson exit_status "$exit_status" '{status:"failed",source:$source,failure_class:$failure_class,exit_status:$exit_status}'
}

canonical_capture_command() {
  local capture_input="" classification="" content="" due="" deadline="" existing_task_id=""
  local dry_run=false technical_failure=false json_mode=false debug_mode=false verbose_mode=false

  while (($#)); do
    case "$1" in
      --json)
        json_mode=true
        shift
        ;;
      --debug)
        debug_mode=true
        shift
        ;;
      --verbose)
        verbose_mode=true
        shift
        ;;
      --capture-input)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        capture_input="$2"
        shift 2
        ;;
      --class|--classification)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        classification="$2"
        shift 2
        ;;
      --content)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        content="$2"
        shift 2
        ;;
      --due)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        due="$2"
        shift 2
        ;;
      --deadline|--deadline-date)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        deadline="$2"
        shift 2
        ;;
      --existing-task-id)
        [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
        existing_task_id="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      --technical-failure)
        technical_failure=true
        shift
        ;;
      *)
        emit_failed invalid_argument
        ;;
    esac
  done

  local capture_args=()
  [[ "$json_mode" == true ]] && capture_args+=(--json)
  [[ "$debug_mode" == true ]] && capture_args+=(--debug)
  [[ "$verbose_mode" == true ]] && capture_args+=(--verbose)
  [[ -n "$capture_input" ]] && capture_args+=(--input "$capture_input")
  [[ -n "$classification" ]] && capture_args+=(--class "$classification")
  [[ -n "$content" ]] && capture_args+=(--content "$content")
  [[ -n "$due" ]] && capture_args+=(--due "$due")
  [[ -n "$deadline" ]] && capture_args+=(--deadline "$deadline")
  [[ -n "$existing_task_id" ]] && capture_args+=(--existing-task-id "$existing_task_id")
  [[ "$dry_run" == true ]] && capture_args+=(--dry-run)
  [[ "$technical_failure" == true ]] && capture_args+=(--technical-failure)

  local capture_file capture_status capture_result checked_at visible_acknowledgment checkpoint_status complete write_action
  local result failure_class jen_action operator_message handoff_id detail_json extra_json envelope_status
  checked_at="$(now_utc)"
  capture_file=$(mktemp)
  capture_status=0
  run_capture_json "$capture_file" "${capture_args[@]}" || capture_status=$?
  capture_result="$(cat "$capture_file")"
  checkpoint_status="$(jq -r '.status // "failed"' <<<"$capture_result")"
  result="$(jq -r '.result // "failed"' <<<"$capture_result")"
  failure_class="$(jq -r '.failure_class // "technical_failure"' <<<"$capture_result")"
  jen_action="$(jq -r '.jen_action // "stop_and_handoff_to_moss"' <<<"$capture_result")"
  operator_message="$(jq -r '.operator_message // "The Todoist wrapper path is not working correctly right now, so I am handing this to Moss."' <<<"$capture_result")"
  handoff_id="$(jq -r '.handoff_id // empty' <<<"$capture_result")"
  write_action="$(jq -r '.action // empty' <<<"$capture_result")"
  complete=true

  if [[ "$capture_status" != 0 || "$checkpoint_status" == "failed" || "$result" == "failed" || "$result" == "partial" ]]; then
    visible_acknowledgment="I can't write Todoist right now; technical handoff needed."
    write_action="technical-handoff"
    complete=false
    detail_json="$(jq -nc \
      --arg wrapper_name jen-todoist-interaction-loop \
      --arg checked_at "$checked_at" \
      --argjson checkpoint "$capture_result" \
      '{wrapper_name:$wrapper_name,checked_at:$checked_at,mode:"canonical_capture",checkpoint:$checkpoint,mutation_attempted:($checkpoint.detail.mutation_attempted // false),mutation_state:($checkpoint.result // "failed"),safe_summary:($checkpoint.operator_message // "Technical handoff required.")}')"
    extra_json="$(jq -nc \
      --arg checked_at "$checked_at" \
      --arg visible_acknowledgment "$visible_acknowledgment" \
      --arg write_action "$write_action" \
      --argjson checkpoint "$capture_result" \
      --argjson complete false \
      --arg failure_class "$failure_class" \
      '{checked_at:$checked_at,mode:"canonical_capture",visible_acknowledgment:$visible_acknowledgment,write_action:$write_action,checkpoint:$checkpoint,failures:[{source:"canonical_capture",failure_class:$failure_class}],complete:$complete}')"
    json_out "$(jen_emit_envelope "$CONTRACT_VERSION" failed "$result" "$failure_class" "$jen_action" "$operator_message" "$handoff_id" "$detail_json" "$extra_json")"
    rm -f "$capture_file"
    exit 1
  fi

  case "$(jq -r '.outcome // empty' <<<"$capture_result")" in
    no-write|keep_chat_local)
      visible_acknowledgment="I'm keeping this chat-local because it is not a Todoist task."
      write_action="chat-local"
      ;;
    ambiguous|clarify_or_not_written_yet)
      visible_acknowledgment="I haven't written this yet because the task details are still ambiguous."
      write_action="clarify-first"
      ;;
    would-update|would_update|updated)
      visible_acknowledgment="I found the existing task and adjusted it: approved wrapper path only."
      [[ -n "$write_action" ]] || write_action="update-existing"
      ;;
    would-create|would_create|created)
      visible_acknowledgment="I updated Todoist: approved wrapper path only."
      [[ -n "$write_action" ]] || write_action="capture-task"
      ;;
    *)
      visible_acknowledgment="$operator_message"
      ;;
  esac

  detail_json="$(jq -nc \
    --arg wrapper_name jen-todoist-interaction-loop \
    --arg checked_at "$checked_at" \
    --argjson checkpoint "$capture_result" \
    '{wrapper_name:$wrapper_name,checked_at:$checked_at,mode:"canonical_capture",checkpoint:$checkpoint,mutation_attempted:($checkpoint.detail.mutation_attempted // false),mutation_state:($checkpoint.result // "no_change"),safe_summary:($checkpoint.operator_message // null)}')"
  extra_json="$(jq -nc \
    --arg checked_at "$checked_at" \
    --arg visible_acknowledgment "$visible_acknowledgment" \
    --arg write_action "$write_action" \
    --argjson checkpoint "$capture_result" \
    --argjson complete true \
    '{checked_at:$checked_at,mode:"canonical_capture",visible_acknowledgment:$visible_acknowledgment,write_action:$write_action,checkpoint:$checkpoint,complete:$complete}')"
  envelope_status="ok"
  [[ "$result" == "partial" ]] && envelope_status="partial"
  json_out "$(jen_emit_envelope "$CONTRACT_VERSION" "$envelope_status" "$result" "$failure_class" "$jen_action" "$operator_message" "$handoff_id" "$detail_json" "$extra_json")"
  rm -f "$capture_file"
  [[ "$result" != "failed" ]]
}

from_date=""
to_date=""
include_due_window=true
canonical_mode=false
canonical_args=()

while (($#)); do
  case "$1" in
    --canonical-capture)
      canonical_mode=true
      shift
      ;;
    --json|--debug|--verbose)
      canonical_args+=("$1")
      shift
      ;;
    --capture-input|--class|--classification|--content|--due|--deadline|--deadline-date|--existing-task-id)
      canonical_args+=("$1")
      [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
      canonical_args+=("$2")
      shift 2
      ;;
    --dry-run|--technical-failure)
      canonical_args+=("$1")
      shift
      ;;
    --from)
      [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
      from_date="$2"
      shift 2
      ;;
    --to)
      [[ -n "${2:-}" && "${2:-}" != --* ]] || emit_failed invalid_argument
      to_date="$2"
      shift 2
      ;;
    --no-due-window)
      include_due_window=false
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage: jen-todoist-interaction-loop [--from YYYY-MM-DD --to YYYY-MM-DD] [--no-due-window]
       jen-todoist-interaction-loop --canonical-capture [--capture-input fixture.json] [--class NOT_A_TASK|AMBIGUOUS|CANONICAL_TASK_UPDATE] [--content TEXT] [--due TEXT] [--deadline YYYY-MM-DD] [--existing-task-id TASK_ID] [--dry-run]

Default mode runs the bounded Todoist interaction observation loop and prints one JSON object.
Canonical mode runs the approved Todoist canonical capture checkpoint and prints one JSON object.
EOF
      exit 0
      ;;
    *)
      emit_failed invalid_argument
      ;;
  esac
done

if [[ "$canonical_mode" == true ]]; then
  canonical_capture_command "${canonical_args[@]}"
  exit $?
fi

if [[ -z "$from_date" ]]; then
  from_date="$(date +%F)"
fi
if [[ -z "$to_date" ]]; then
  to_date="$(date -d "$from_date +2 days" +%F 2>/dev/null || true)"
fi
valid_date_ymd "$from_date" || emit_failed invalid_argument
valid_date_ymd "$to_date" || emit_failed invalid_argument
[[ "$from_date" < "$to_date" || "$from_date" == "$to_date" ]] || emit_failed invalid_argument

checked_at="$(now_utc)"
recent_file=$(mktemp)
signals_file=$(mktemp)
due_file=$(mktemp)
cleanup() {
  rm -f "$recent_file" "$signals_file" "$due_file"
}
trap cleanup EXIT

recent_status=0
run_runtime_json "$recent_file" read-recent-completed || recent_status=$?
recent_result="$(wrap_runtime_result recent_completed "$recent_status" "$recent_file")"

signals_status=0
run_runtime_json "$signals_file" classify-interaction-signals || signals_status=$?
signals_result="$(wrap_runtime_result interaction_signals "$signals_status" "$signals_file")"

due_result='{"status":"skipped","source":"due_pressure","reason":"no_due_window"}'
due_status=0
if [[ "$include_due_window" == true ]]; then
  run_due_semantics_json "$due_file" live-due-window --from "$from_date" --to "$to_date" || due_status=$?
  due_result="$(wrap_runtime_result due_pressure "$due_status" "$due_file" | jq -c --arg from "$from_date" --arg to "$to_date" '. + {from:$from,to:$to}')"
fi

status="failed"
complete=false
recent_ok="$(jq -r '.status == "ok"' <<<"$recent_result")"
signals_ok="$(jq -r '.status == "ok"' <<<"$signals_result")"
due_ok="$(jq -r '(.status == "ok") or (.status == "skipped")' <<<"$due_result")"
recent_live_ok="$(jq -r '.status == "ok" and .output.status == "ok" and .output.source == "live"' <<<"$recent_result")"
due_live_ok="$(jq -r '.status == "ok" and .output.status == "ok" and .output.source == "live"' <<<"$due_result")"

# Useful live signal means a live Todoist read succeeded. Metadata-only or observational fallback output does not count.
if [[ "$recent_ok" == true && "$signals_ok" == true && "$due_ok" == true && ( "$recent_live_ok" == true || "$due_live_ok" == true ) ]]; then
  status="ok"
  complete=true
elif [[ "$recent_live_ok" == true || "$due_live_ok" == true ]]; then
  status="partial"
  complete=false
else
  status="failed"
  complete=false
fi

failures="$(jq -nc \
  --argjson recent "$recent_result" \
  --argjson signals "$signals_result" \
  --argjson due "$due_result" \
  '[$recent,$signals,$due]
   | map(select(.status == "failed" or .status == "degraded"))
   | map({source:.source,failure_class:(.failure_class // .runtime_status // "runtime_degraded"),runtime_source:(.runtime_source // null),exit_status:(.exit_status // null)})')"

json_out "$(jq -nc \
  --arg contract_version "$CONTRACT_VERSION" \
  --arg status "$status" \
  --arg checked_at "$checked_at" \
  --argjson complete "$complete" \
  --arg from "$from_date" \
  --arg to "$to_date" \
  --argjson recent "$recent_result" \
  --argjson signals "$signals_result" \
  --argjson due "$due_result" \
  --argjson failures "$failures" \
  '{contract_version:$contract_version,status:$status,checked_at:$checked_at,window:{from:$from,to:$to},recent_completed:$recent,interaction_signals:$signals,due_pressure:$due,failures:$failures,complete:$complete}')"

[[ "$status" != failed ]]
