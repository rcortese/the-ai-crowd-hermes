#!/usr/bin/env bash
set -euo pipefail

CONTRACT_VERSION="jen-todoist-due-semantics.v1"
WORKSPACE_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
TASK_RUNTIME="${JEN_TODOIST_DUE_SEMANTICS_TASK_RUNTIME:-$WORKSPACE_ROOT/bin/jen-task-runtime}"

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

json_out() {
  printf '%s\n' "$1"
}

emit_failed() {
  local command="$1"
  local failure_class="$2"
  json_out "$(jq -nc \
    --arg contract_version "$CONTRACT_VERSION" \
    --arg command "$command" \
    --arg status failed \
    --arg failure_class "$failure_class" \
    '{contract_version:$contract_version,command:$command,status:$status,failure_class:$failure_class,complete:false}')"
  exit 1
}

valid_date_ymd() {
  [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && [[ "$(date -d "$1" +%F 2>/dev/null || true)" == "$1" ]]
}

require_option_value() {
  local command="$1"
  local value="${2:-}"
  if [[ -z "$value" || "$value" == --* ]]; then
    emit_failed "$command" invalid_argument
  fi
}

usage() {
  cat <<'EOF'
Usage:
  jen-todoist-due-semantics classify [--today YYYY-MM-DD]
  jen-todoist-due-semantics live-due-window --from YYYY-MM-DD --to YYYY-MM-DD [--today YYYY-MM-DD]

Read-only helper that classifies Todoist due/past-date task semantics before Jen uses lateness wording.
Live mode may call only bin/jen-task-runtime read-due-window; it does not call the Todoist provider adapter directly and performs no mutations.
EOF
}

classify_tasks_json() {
  local tasks_json="$1"
  local command="$2"
  local source="$3"
  local today="$4"
  local from_date="$5"
  local to_date="$6"
  local checked_at
  checked_at="$(now_utc)"

  jq -nc \
    --arg contract_version "$CONTRACT_VERSION" \
    --arg command "$command" \
    --arg status ok \
    --arg source "$source" \
    --arg checked_at "$checked_at" \
    --arg today "$today" \
    --arg from "$from_date" \
    --arg to "$to_date" \
    --argjson tasks_in "$tasks_json" '
    def text_blob:
      [(.content // ""), (.description // ""), ((.labels // []) | join(" ")), (.due.string // ""), (.deadline.date // ""), (.deadline.datetime // "")]
      | join(" ")
      | ascii_downcase;

    def has_due: ((.due | type) == "object") and ((.due.date // "") != "");
    def past_due($today): has_due and ((.due.date // "") < $today);
    def has_hard_deadline_cue:
      ((.deadline | type) == "object")
      or (text_blob | test("\\b(boleto|conta|vencimento|vencer|pagar|pagamento|imposto|consulta|m[eé]dico|dentista|appointment|deadline|due by|entregar|entrega|contrato|documento|renova[cç][aã]o|license|licen[cç]a|invoice|fatura)\\b"));
    def content_present: (((.content // "") | gsub("\\s+"; "") | length) > 0);
    def recurring_hard_obligation: has_due and (.due.is_recurring == true) and has_hard_deadline_cue;
    def category($today):
      if recurring_hard_obligation then "recurring_hard_obligation"
      elif has_due and (.due.is_recurring == true) then "recurring_maintenance"
      elif has_hard_deadline_cue then "hard_deadline"
      elif has_due and content_present then "soft_surface"
      else "ambiguous" end;
    def confidence($today):
      if recurring_hard_obligation then "high"
      elif has_due and (.due.is_recurring == true) then "high"
      elif ((.deadline | type) == "object") then "high"
      elif has_hard_deadline_cue then "medium"
      elif has_due and content_present and past_due($today) then "low"
      elif has_due and content_present then "medium"
      else "low" end;
    def reason($today):
      if recurring_hard_obligation then "Todoist marks a recurring due date and hard-deadline evidence; treat due as intended execution/cadence and deadline as the current-cycle cutoff."
      elif has_due and (.due.is_recurring == true) then "Todoist marks the due date as recurring, so treat it as cadence/maintenance rather than automatic debt."
      elif ((.deadline | type) == "object") then "Todoist exposes an explicit deadline object, so stronger deadline handling is allowed."
      elif has_hard_deadline_cue then "Task text, labels, due string, or deadline fields contain real-world deadline cues."
      elif has_due and content_present and past_due($today) then "Task has a date before today, but no hard-deadline cue; past_due_raw is only a date signal."
      elif has_due and content_present then "Task has a due date but no hard-deadline cue; treat it as a surfaced candidate."
      else "Insufficient due/content evidence to classify date semantics safely." end;
    def suggested_action($today):
      (category($today)) as $category
      | if $category == "hard_deadline" then "Do it, renegotiate it, reschedule it explicitly, or set/verify deadline."
        elif $category == "recurring_hard_obligation" then "Preserve recurring due as intended execution/cadence; verify or update the current-cycle deadline from policy."
        elif $category == "recurring_maintenance" then "Choose the next viable occurrence or re-anchor the cadence."
        elif $category == "soft_surface" then "Keep it today, move it to `Esta Semana`, or remove the due date."
        else "Ask one focused question or suggest a short review." end;
    def signals($today):
      ([
        (if has_due then "has_due_date" else empty end),
        (if past_due($today) then "past_due_raw" else empty end),
        (if (.due.is_recurring == true) then "todoist_recurring_due" else empty end),
        (if ((.deadline | type) == "object") then "todoist_deadline_object" else empty end),
        (if has_hard_deadline_cue then "hard_deadline_cue" else empty end)
      ] | unique);

    ($tasks_in | if type == "array" then . else error("tasks_not_array") end) as $input_tasks
    | ($input_tasks | map(
        . as $task
        | ($task | category($today)) as $category
        | {
            id: (($task.id // $task.task_id // null) | tostring),
            content: ($task.content // ""),
            due: (if (($task.due | type) == "object") then $task.due else null end),
            deadline: (if (($task.deadline | type) == "object") then $task.deadline else null end),
            past_due_raw: ($task | past_due($today)),
            classification: {
              category: $category,
              confidence: ($task | confidence($today)),
              reason: ($task | reason($today)),
              suggested_action: ($task | suggested_action($today))
            },
            signals: ($task | signals($today))
          }
      )) as $classified
    | {
        contract_version:$contract_version,
        command:$command,
        status:$status,
        source:$source,
        checked_at:$checked_at,
        today:$today,
        from:(if $from == "" then null else $from end),
        to:(if $to == "" then null else $to end),
        summary:{
          task_count:($classified|length),
          category_counts:($classified | group_by(.classification.category) | map({key:.[0].classification.category,value:length}) | from_entries)
        },
        tasks:$classified,
        complete:true
      }
  ' 2>/dev/null || emit_failed "$command" provider_shape_invalid
}

classify_command() {
  local today="$(date +%F)"
  while (($#)); do
    case "$1" in
      --today)
        require_option_value classify "${2:-}"
        today="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        emit_failed classify invalid_argument
        ;;
    esac
  done
  valid_date_ymd "$today" || emit_failed classify invalid_argument

  local input_json
  if ! input_json="$(cat)" || [[ -z "$input_json" ]] || ! jq -e 'type == "array"' <<<"$input_json" >/dev/null 2>&1; then
    emit_failed classify provider_shape_invalid
  fi
  classify_tasks_json "$input_json" classify stdin "$today" "" ""
}

live_due_window_command() {
  local from_date="" to_date="" today="$(date +%F)"
  while (($#)); do
    case "$1" in
      --from)
        require_option_value live-due-window "${2:-}"
        from_date="$2"
        shift 2
        ;;
      --to)
        require_option_value live-due-window "${2:-}"
        to_date="$2"
        shift 2
        ;;
      --today)
        require_option_value live-due-window "${2:-}"
        today="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        emit_failed live-due-window invalid_argument
        ;;
    esac
  done
  if [[ -z "$from_date" || -z "$to_date" ]]; then
    emit_failed live-due-window invalid_argument
  fi
  valid_date_ymd "$from_date" || emit_failed live-due-window invalid_argument
  valid_date_ymd "$to_date" || emit_failed live-due-window invalid_argument
  valid_date_ymd "$today" || emit_failed live-due-window invalid_argument
  [[ "$from_date" < "$to_date" || "$from_date" == "$to_date" ]] || emit_failed live-due-window invalid_argument

  local runtime_file runtime_status tasks_json failure_class
  runtime_file=$(mktemp)
  set +e
  "$TASK_RUNTIME" read-due-window --from "$from_date" --to "$to_date" >"$runtime_file" 2>/dev/null
  runtime_status=$?
  set -e
  if [[ "$runtime_status" != "0" ]] || ! jq empty "$runtime_file" >/dev/null 2>&1; then
    failure_class="$(jq -r '.failure_class // empty' "$runtime_file" 2>/dev/null || true)"
    rm -f "$runtime_file"
    emit_failed live-due-window "${failure_class:-runtime_failure}"
  fi
  if ! jq -e '.status == "ok" and .source == "live" and (.tasks | type) == "array" and .complete == true' "$runtime_file" >/dev/null; then
    rm -f "$runtime_file"
    emit_failed live-due-window provider_shape_invalid
  fi
  tasks_json="$(jq -c '.tasks' "$runtime_file")"
  rm -f "$runtime_file"
  classify_tasks_json "$tasks_json" live-due-window live "$today" "$from_date" "$to_date"
}

main() {
  local command="${1:-}"
  shift || true
  case "$command" in
    classify) classify_command "$@" ;;
    live-due-window) live_due_window_command "$@" ;;
    -h|--help|help) usage ;;
    *) emit_failed unknown-command invalid_argument ;;
  esac
}

main "$@"
