  cleanup_files "$pre_stdout" "$pre_stderr" "$description_stdout" "$description_stderr"
  json_out "$output_json"
}

move_task_command() {
  local task_id="" project_id=""
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value move-task "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --project-id|--list-id|--target-project-id|--target-list-id)
        require_option_value move-task "${2:-}"
        project_id="$2"
        shift 2
        ;;
      *)
        emit_failed move-task invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || -z "$project_id" ]]; then
    emit_failed move-task invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed move-task state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed move-task "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_project_move "$task_id" "$project_id" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed move-task request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed move-task request_failure "$mutation_extra"
      ;;
    blocked)
      emit_failed move-task mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      emit_failed move-task mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      emit_failed move-task idempotency_collision "$mutation_extra"
      ;;
    unsafe_replay_state|retry_partial)
      emit_failed move-task unsafe_replay_state "$mutation_extra"
      ;;
    execute)
      ;;
    *)
      emit_failed move-task request_failure "$mutation_extra"
      ;;
  esac

  local move_stdout move_stderr adapter_status failure_class runtime_json result_json output_json
  move_stdout=$(mktemp)
  move_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$move_stdout" "$move_stderr" move-task "$task_id" "$project_id" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$move_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed move-task state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"move-task",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed move-task state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$move_stdout" "$move_stderr"
    emit_failed move-task "$failure_class" "$mutation_extra"
  fi

  local actual_project_id
  actual_project_id="$(jq -r '.project_id // empty' "$move_stdout" 2>/dev/null || true)"
  if [[ "$actual_project_id" != "$project_id" ]]; then
    failure_class=verification_failed
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed move-task state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" --arg actual_project_id "$actual_project_id" --arg expected_project_id "$project_id" '{runtime_schema:$runtime_schema,failed_step:"move-task-verify",failure_class:$failure_class,actual_project_id:$actual_project_id,expected_project_id:$expected_project_id}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed move-task state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$move_stdout" "$move_stderr"
    emit_failed move-task "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed move-task state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command move-task --arg status ok --arg operation move-task --argjson verified true --arg project_id "$project_id" --argjson task "$(cat "$move_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,project_id:$project_id,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed move-task state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$move_stdout" "$move_stderr"
  json_out "$output_json"
}




ensure_observation_baseline_command() {
  local ts limit ttl_hours force=false baseline_json baseline_valid=false refreshed=false reason=fresh stdout_file stderr_file
  ts="$(now_utc)"
  limit=200
  ttl_hours=48
  while (($#)); do
    case "$1" in
      --limit)
        require_option_value ensure-observation-baseline "${2:-}"
        limit="${2:-}"
        shift 2
        ;;
      --ttl-hours)
        require_option_value ensure-observation-baseline "${2:-}"
        ttl_hours="${2:-}"
        shift 2
        ;;
      --force)
        force=true
        shift
        ;;
      *)
        emit_failed ensure-observation-baseline invalid_argument
        ;;
    esac
  done
  valid_limit "$limit" || emit_failed ensure-observation-baseline invalid_argument
  valid_ttl_hours "$ttl_hours" || emit_failed ensure-observation-baseline invalid_argument

  baseline_json="$(read_observation_snapshot)"
  local baseline_observed_at="" baseline_age_seconds=null baseline_task_count=0 ttl_seconds
  ttl_seconds=$(( ttl_hours * 3600 ))
  if snapshot_is_valid "$baseline_json"; then
    baseline_valid=true
    baseline_observed_at="$(jq -r '.observed_at' <<<"$baseline_json")"
    baseline_task_count="$(jq -r '.task_count // (.tasks|length)' <<<"$baseline_json")"
    if valid_rfc3339_utc "$baseline_observed_at"; then
      local age
      if age="$(snapshot_age_seconds "$baseline_observed_at" "$ts")" && (( age >= 0 && age <= ttl_seconds )); then
        baseline_age_seconds="$age"
        if [[ "$force" != true ]]; then
          json_out "$(jq -nc             --arg contract_version "$CONTRACT_VERSION"             --arg command ensure-observation-baseline             --arg status ok             --arg source ephemeral-observation-state             --arg observed_at "$ts"             --arg baseline_observed_at "$baseline_observed_at"             --arg provenance ephemeral-active-observation-snapshot             --arg purpose baseline_ensure             --argjson refreshed false             --argjson force false             --argjson limit "$limit"             --argjson ttl_hours "$ttl_hours"             --argjson baseline_age_seconds "$baseline_age_seconds"             --argjson task_count "$baseline_task_count"             '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,baseline_observed_at:$baseline_observed_at,baseline_age_seconds:$baseline_age_seconds,refreshed:$refreshed,refresh_reason:"fresh",force:$force,summary:{task_count:$task_count},limit:$limit,ttl_hours:$ttl_hours,complete:true,provenance:$provenance,purpose:$purpose,note:"Fresh ephemeral active-task observation baseline already exists; not overwritten."}')"
          return 0
        fi
        reason=forced
      else
        reason=stale
      fi
    else
      reason=corrupt
    fi
  else
    reason=missing
  fi

  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  local adapter_status
  adapter_status=0
  adapter_run "$stdout_file" "$stderr_file" active-snapshot "$limit" || adapter_status=$?
  if [[ "$adapter_status" != "0" ]]; then
    local failure_class runtime runtime_json
    failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
    runtime="$(state_read_runtime)"
    runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
    state_write_runtime "$runtime_json" || true
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed ensure-observation-baseline "$failure_class"
  fi

  local provider_json current_tasks current_count snapshot_json runtime runtime_json
  provider_json="$(cat "$stdout_file")"
  if ! assert_complete_window <<<"$provider_json" 2>/dev/null; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed ensure-observation-baseline provider_shape_invalid
  fi
  if ! current_tasks="$(normalize_snapshot_tasks <<<"$provider_json" 2>/dev/null)"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed ensure-observation-baseline provider_shape_invalid
  fi
  current_count="$(jq 'length' <<<"$current_tasks")"
  snapshot_json="$(build_observation_snapshot_json "$ts" "$current_tasks" "$limit" "$ttl_hours")"
  if ! write_observation_snapshot "$snapshot_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed ensure-observation-baseline state_write_failed
  fi

  runtime="$(state_read_runtime)"
  runtime_json="$(jq -c --arg ts "$ts" --arg reason "$reason" --argjson count "$current_count" --argjson limit "$limit" --argjson ttl_hours "$ttl_hours" '
    .ensure_observation_baseline.last_ensure = {observed_at:$ts, refreshed:true, refresh_reason:$reason, task_count:$count, limit:$limit, ttl_hours:$ttl_hours, provenance:"ephemeral-active-observation-snapshot"}
    | .last_verified_at = $ts
    | .last_failure_class = null
  ' <<<"$runtime")"
  if ! state_write_runtime "$runtime_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed ensure-observation-baseline state_write_failed
  fi

  json_out "$(jq -nc     --arg contract_version "$CONTRACT_VERSION"     --arg command ensure-observation-baseline     --arg status ok     --arg source live     --arg observed_at "$ts"     --arg baseline_observed_at "$ts"     --arg refresh_reason "$reason"     --arg provenance ephemeral-active-observation-snapshot     --arg purpose baseline_ensure     --argjson refreshed true     --argjson force "$force"     --argjson limit "$limit"     --argjson ttl_hours "$ttl_hours"     --argjson task_count "$current_count"     '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,baseline_observed_at:$baseline_observed_at,baseline_age_seconds:0,refreshed:$refreshed,refresh_reason:$refresh_reason,force:$force,summary:{task_count:$task_count},limit:$limit,ttl_hours:$ttl_hours,complete:true,provenance:$provenance,purpose:$purpose,note:"Ensured ephemeral active-task observation baseline. Snapshot is ignored, non-canonical, TTL-bound, and not task truth."}')"
  cleanup_files "$stdout_file" "$stderr_file"
}


read_recent_diff_command() {
  local ts since until limit ttl_hours stdout_file stderr_file
  ts="$(now_utc)"
  since=""
  until="$ts"
  limit=200
  ttl_hours=48
  while (($#)); do
    case "$1" in
      --since)
        require_option_value read-recent-diff "${2:-}"
        since="${2:-}"
        shift 2
        ;;
      --until)
        require_option_value read-recent-diff "${2:-}"
        until="${2:-}"
        shift 2
        ;;
      --limit)
        require_option_value read-recent-diff "${2:-}"
        limit="${2:-}"
        shift 2
        ;;
      --ttl-hours)
        require_option_value read-recent-diff "${2:-}"
        ttl_hours="${2:-}"
        shift 2
        ;;
      *)
        emit_failed read-recent-diff invalid_argument
        ;;
    esac
  done
  [[ -n "$since" ]] || emit_failed read-recent-diff invalid_argument
  valid_since_until "$since" "$until" || emit_failed read-recent-diff invalid_argument
  valid_limit "$limit" || emit_failed read-recent-diff invalid_argument
  valid_ttl_hours "$ttl_hours" || emit_failed read-recent-diff invalid_argument

  local until_epoch ts_epoch skew_seconds
  until_epoch="$(rfc3339_epoch "$until")" || emit_failed read-recent-diff invalid_argument
  ts_epoch="$(rfc3339_epoch "$ts")" || emit_failed read-recent-diff invalid_argument
  skew_seconds=300
  if (( until_epoch < ts_epoch - skew_seconds || until_epoch > ts_epoch + skew_seconds )); then
    emit_failed read-recent-diff invalid_argument
  fi

  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  local adapter_status
  adapter_status=0
  adapter_run "$stdout_file" "$stderr_file" active-snapshot "$limit" || adapter_status=$?
  if [[ "$adapter_status" != "0" ]]; then
    local failure_class runtime runtime_json
    failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
    runtime="$(state_read_runtime)"
    runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
    state_write_runtime "$runtime_json" || true
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-diff "$failure_class"
  fi

  local provider_json current_tasks current_count baseline_json baseline_present baseline_observed_at baseline_tasks baseline_count
  provider_json="$(cat "$stdout_file")"
  if [[ "$(jq -r 'type' <<<"$provider_json" 2>/dev/null || true)" == "object" ]]; then
    if ! assert_complete_window <<<"$provider_json" 2>/dev/null; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-recent-diff provider_shape_invalid
    fi
  fi
  if ! current_tasks="$(normalize_snapshot_tasks <<<"$provider_json" 2>/dev/null)"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-diff provider_shape_invalid
  fi
  current_count="$(jq 'length' <<<"$current_tasks")"
  baseline_json="$(read_observation_snapshot)"
  baseline_present=false
  baseline_observed_at=""
  baseline_tasks='[]'
  baseline_count=0
  if [[ "$baseline_json" != "null" ]] && jq -e '(.contract_version == "jen-todoist-observation-snapshot.v1") and ((.tasks|type)=="array") and (.observed_at|type=="string")' <<<"$baseline_json" >/dev/null 2>&1; then
    baseline_present=true
    baseline_observed_at="$(jq -r '.observed_at' <<<"$baseline_json")"
    baseline_tasks="$(jq -c '.tasks' <<<"$baseline_json" | normalize_snapshot_tasks 2>/dev/null || printf '[]')"
    baseline_count="$(jq 'length' <<<"$baseline_tasks")"
  fi

  local status coverage_status coverage_from coverage_to baseline_fresh=false diff_json changed_count added_count removed_count limitations runtime runtime_json snapshot_json
  status=degraded
  coverage_status=none
  coverage_from=""
  coverage_to="$ts"
  diff_json='{"changed":[],"added_to_active_observation":[],"removed_from_active_observation":[]}'
  limitations='["current_active_observation_only","not_historical_event_timeline","removed_from_active_observation_does_not_imply_deleted_completed_or_moved"]'

  if [[ "$baseline_present" == true ]] && valid_rfc3339_utc "$baseline_observed_at"; then
    local baseline_epoch since_epoch ttl_seconds
    baseline_epoch="$(rfc3339_epoch "$baseline_observed_at")" || baseline_epoch=0
    since_epoch="$(rfc3339_epoch "$since")" || since_epoch=0
    ttl_seconds=$(( ttl_hours * 3600 ))
    if (( baseline_epoch >= ts_epoch - ttl_seconds && baseline_epoch <= ts_epoch )); then
      baseline_fresh=true
      coverage_from="$baseline_observed_at"
      diff_json="$(build_observation_diff "$baseline_tasks" "$current_tasks")"
      if (( baseline_epoch > since_epoch )); then
        status=degraded
        coverage_status=partial_baseline_after_since
        limitations="$(jq -c '. + ["baseline_after_requested_since_misses_early_interval"]' <<<"$limitations")"
      else
        status=ok
        coverage_status=net_observation_baseline_before_since
        limitations="$(jq -c '. + ["net_diff_only_intermediate_changes_may_cancel_out"]' <<<"$limitations")"
      fi
    else
      limitations="$(jq -c '. + ["baseline_missing_or_stale_no_diff_claim"]' <<<"$limitations")"
    fi
  else
    limitations="$(jq -c '. + ["baseline_missing_or_stale_no_diff_claim"]' <<<"$limitations")"
  fi

  changed_count="$(jq '.changed|length' <<<"$diff_json")"
  added_count="$(jq '.added_to_active_observation|length' <<<"$diff_json")"
  removed_count="$(jq '.removed_from_active_observation|length' <<<"$diff_json")"

  snapshot_json="$(build_observation_snapshot_json "$ts" "$current_tasks" "$limit" "$ttl_hours")"
  if ! write_observation_snapshot "$snapshot_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-diff state_write_failed
  fi

  runtime="$(state_read_runtime)"
  runtime_json="$(jq -c --arg ts "$ts" --arg since "$since" --arg until "$until" --arg status "$status" --arg coverage_status "$coverage_status" --arg baseline_observed_at "$baseline_observed_at" --argjson current_count "$current_count" --argjson baseline_count "$baseline_count" --argjson changed_count "$changed_count" --argjson added_count "$added_count" --argjson removed_count "$removed_count" '
    .read_recent_diff.last_diff_window = {
      since:$since,
      until:$until,
      observed_at:$ts,
      status:$status,
      coverage_status:$coverage_status,
      baseline_observed_at:(if $baseline_observed_at == "" then null else $baseline_observed_at end),
      current_count:$current_count,
      baseline_count:$baseline_count,
      changed_count:$changed_count,
      added_count:$added_count,
      removed_count:$removed_count,
      evidence_level:"ephemeral-active-observation-diff"
    }
    | .last_verified_at = $ts
    | .last_failure_class = null
  ' <<<"$runtime")"
  if ! state_write_runtime "$runtime_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-diff state_write_failed
  fi

  json_out "$(jq -nc     --arg contract_version "$CONTRACT_VERSION"     --arg command read-recent-diff     --arg status "$status"     --arg source live     --arg observed_at "$ts"     --arg since "$since"     --arg until "$until"     --arg baseline_observed_at "$baseline_observed_at"     --arg current_observed_at "$ts"     --arg coverage_from "$coverage_from"     --arg coverage_to "$coverage_to"     --arg coverage_status "$coverage_status"     --argjson baseline_present "$baseline_present"     --argjson baseline_fresh "$baseline_fresh"     --argjson diff "$diff_json"     --argjson limitations "$limitations"     --argjson current_count "$current_count"     --argjson baseline_count "$baseline_count"     '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,requested_window:{since:$since,until:$until},baseline_present:$baseline_present,baseline_fresh:$baseline_fresh,baseline_observed_at:(if $baseline_observed_at == "" then null else $baseline_observed_at end),current_observed_at:$current_observed_at,coverage_interval:{from:(if $coverage_from == "" then null else $coverage_from end),to:$coverage_to},coverage_status:$coverage_status,diff:$diff,summary:{baseline_task_count:$baseline_count,current_task_count:$current_count,changed_count:($diff.changed|length),added_to_active_observation_count:($diff.added_to_active_observation|length),removed_from_active_observation_count:($diff.removed_from_active_observation|length)},evidence_level:"ephemeral-active-observation-diff",limitations:$limitations,complete:true,note:"Ephemeral active-task observation diff. Compares previous observed active baseline to current live active state only; it does not reconstruct arbitrary historical windows.",provenance:"ephemeral-active-observation-snapshot"}')"
  cleanup_files "$stdout_file" "$stderr_file"
  return 0
}

read_activity_log_command() {
  local ts since until limit stdout_file stderr_file
  ts="$(now_utc)"
  since=""
  until="$ts"
  limit=100
  while (($#)); do
    case "$1" in
      --since)
        require_option_value read-activity-log "${2:-}"
        since="${2:-}"
        shift 2
        ;;
      --until)
        require_option_value read-activity-log "${2:-}"
        until="${2:-}"
        shift 2
        ;;
      --limit)
        require_option_value read-activity-log "${2:-}"
        limit="${2:-}"
        shift 2
        ;;
      *)
        emit_failed read-activity-log invalid_argument
        ;;
    esac
  done
  [[ -n "$since" ]] || emit_failed read-activity-log invalid_argument
  valid_since_until "$since" "$until" || emit_failed read-activity-log invalid_argument
  [[ "$limit" =~ ^[0-9]+$ ]] && [[ "$limit" -ge 1 && "$limit" -le 100 ]] || emit_failed read-activity-log invalid_argument

  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  local adapter_status
  adapter_status=0
  adapter_run "$stdout_file" "$stderr_file" activity-window "$since" "$until" "$limit" || adapter_status=$?
  if [[ "$adapter_status" == "0" ]]; then
    local provider_json events count runtime runtime_json
    provider_json="$(cat "$stdout_file")"
    if ! assert_complete_window <<<"$provider_json" 2>/dev/null; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-activity-log provider_shape_invalid
    fi
    if ! events="$(normalize_activity_events <<<"$provider_json" 2>/dev/null)"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-activity-log provider_shape_invalid
    fi
    count="$(jq 'length' <<<"$events")"
    runtime="$(state_read_runtime)"
    runtime_json="$(jq -c --arg ts "$ts" --arg since "$since" --arg until "$until" --argjson count "$count" '
      .read_activity_log.last_activity_window = {since:$since, until:$until, observed_at:$ts, count:$count, evidence_level:"provider-activity-log"}
      | .last_verified_at = $ts
      | .last_failure_class = null
    ' <<<"$runtime")"
    if ! state_write_runtime "$runtime_json"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-activity-log state_write_failed
    fi
    json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-activity-log --arg status ok --arg source live --arg observed_at "$ts" --arg since "$since" --arg until "$until" --arg evidence_level provider-activity-log --arg provenance live-activity-log-window --arg note 'Live Todoist Activity Log window. The until/date_to bound is exclusive. This is provider event evidence, not a complete field-level before/after diff.' --argjson events "$events" '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,since:$since,until:$until,events:$events,summary:{activity_event_count:($events|length)},evidence_level:$evidence_level,limitations:["activity_log_plan_dependent","provider_update_fields_limited","before_after_values_not_guaranteed","snapshot_diff_required_for_full_field_comparison"],complete:true,note:$note,provenance:$provenance}')"
    cleanup_files "$stdout_file" "$stderr_file"
    return 0
  fi

  local failure_class runtime runtime_json
  failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
  runtime="$(state_read_runtime)"
  runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
  if ! state_write_runtime "$runtime_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-activity-log state_write_failed
  fi
  cleanup_files "$stdout_file" "$stderr_file"
  emit_failed read-activity-log "$failure_class"
}

read_recent_activity_command() {
  local ts since until limit stdout_file stderr_file
  ts="$(now_utc)"
  since=""
  until="$ts"
  limit=200
  while (($#)); do
    case "$1" in
      --since)
        require_option_value read-recent-activity "${2:-}"
        since="${2:-}"
        shift 2
        ;;
      --until)
        require_option_value read-recent-activity "${2:-}"
        until="${2:-}"
        shift 2
        ;;
      --limit)
        require_option_value read-recent-activity "${2:-}"
        limit="${2:-}"
        shift 2
        ;;
      *)
        emit_failed read-recent-activity invalid_argument
        ;;
    esac
  done
  [[ -n "$since" ]] || emit_failed read-recent-activity invalid_argument
  valid_since_until "$since" "$until" || emit_failed read-recent-activity invalid_argument
  valid_limit "$limit" || emit_failed read-recent-activity invalid_argument

  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  if adapter_run "$stdout_file" "$stderr_file" active-updated-window "$since" "$until" "$limit"; then
    local provider_json tasks count runtime runtime_json
    provider_json="$(cat "$stdout_file")"
    if ! assert_complete_window <<<"$provider_json" 2>/dev/null; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-recent-activity provider_shape_invalid
    fi
    if ! tasks="$(normalize_active_tasks <<<"$provider_json" | jq -c --arg since "$since" --arg until "$until" 'map(select((.updated_at // null) != null and .updated_at >= $since and .updated_at <= $until))' 2>/dev/null)"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-recent-activity provider_shape_invalid
    fi
    count="$(jq 'length' <<<"$tasks")"
    runtime="$(state_read_runtime)"
    runtime_json="$(jq -c --arg ts "$ts" --arg since "$since" --arg until "$until" --argjson count "$count" '
      .read_recent_activity.last_activity_window = {since:$since, until:$until, observed_at:$ts, count:$count, evidence_level:"current-active-updated-at"}
      | .last_verified_at = $ts
      | .last_failure_class = null
    ' <<<"$runtime")"
    if ! state_write_runtime "$runtime_json"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-recent-activity state_write_failed
    fi
    json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-recent-activity --arg status ok --arg source live --arg observed_at "$ts" --arg since "$since" --arg until "$until" --arg evidence_level current-active-updated-at --arg note 'Live active-task activity window from Todoist updated_at. This is current-state evidence of recently updated active tasks, not a field-level diff. Task bodies are returned for this request only; runtime metadata stores only window bounds and count.' --arg provenance live-active-updated-window --argjson tasks "$tasks" '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,since:$since,until:$until,tasks:$tasks,summary:{activity_task_count:($tasks|length)},evidence_level:$evidence_level,limitations:["field_level_diff_unavailable_without_task_body_cache","completed_tasks_are_reported_separately"],complete:true,note:$note,provenance:$provenance}')"
    cleanup_files "$stdout_file" "$stderr_file"
    return 0
  fi

  local adapter_status failure_class runtime runtime_json
  adapter_status=$?
  failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
  runtime="$(state_read_runtime)"
  runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
  if ! state_write_runtime "$runtime_json"; then
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-activity state_write_failed
  fi
  cleanup_files "$stdout_file" "$stderr_file"
  emit_failed read-recent-activity "$failure_class"
}

read_recent_completed_command() {
  local ts stdout_file stderr_file since until mode
  ts="$(now_utc)"
  since=""
  until="$ts"
  mode="summary"
  while (($#)); do
    case "$1" in
      --since)
        require_option_value read-recent-completed "${2:-}"
        since="${2:-}"
        shift 2
        ;;
      --until)
        require_option_value read-recent-completed "${2:-}"
        until="${2:-}"
        shift 2
        ;;
      --tasks)
        mode="tasks"
        shift
        ;;
      *)
        emit_failed read-recent-completed invalid_argument
        ;;
    esac
  done
  if [[ "$mode" == "tasks" && -z "$since" ]]; then
    since="$(date -u -d '7 days ago' +"%Y-%m-%dT%H:%M:%SZ")"
  fi
  if [[ "$mode" == "tasks" ]]; then
    if ! valid_rfc3339_utc "$since" || ! valid_rfc3339_utc "$until" || [[ "$since" > "$until" ]]; then
      emit_failed read-recent-completed invalid_argument
    fi
  fi
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)

  if [[ "$mode" == "tasks" ]]; then
    if adapter_run "$stdout_file" "$stderr_file" completed-by-completion-date "$since" "$until" 100; then
      local provider_json tasks count runtime runtime_json
      provider_json="$(cat "$stdout_file")"
      if ! assert_complete_window <<<"$provider_json" 2>/dev/null; then
        cleanup_files "$stdout_file" "$stderr_file"
        emit_failed read-recent-completed provider_shape_invalid
      fi
      if ! tasks="$(normalize_completed_tasks <<<"$provider_json" 2>/dev/null)"; then
        cleanup_files "$stdout_file" "$stderr_file"
        emit_failed read-recent-completed provider_shape_invalid
      fi
      count="$(jq 'length' <<<"$tasks")"
      runtime="$(state_read_runtime)"
      runtime_json="$(jq -c --arg ts "$ts" --arg since "$since" --arg until "$until" --argjson count "$count" '
        .read_recent_completed.last_task_window = {since:$since, until:$until, observed_at:$ts, count:$count}
        | .last_verified_at = $ts
        | .last_failure_class = null
      ' <<<"$runtime")"
      if ! state_write_runtime "$runtime_json"; then
        emit_failed read-recent-completed state_write_failed
      fi
      json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-recent-completed --arg status ok --arg source live --arg observed_at "$ts" --arg since "$since" --arg until "$until" --arg note 'Live completed-task window from Todoist by completion date. Task bodies are returned for this request only; runtime metadata stores only window bounds and count.' --arg provenance live-completed-window --argjson tasks "$tasks" '{contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,since:$since,until:$until,tasks:$tasks,summary:{completed_task_count:($tasks|length)},complete:true,note:$note,provenance:$provenance}')"
      cleanup_files "$stdout_file" "$stderr_file"
      return 0
    fi

    local adapter_status failure_class runtime runtime_json
    adapter_status=$?
    failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
    runtime="$(state_read_runtime)"
    runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
    if ! state_write_runtime "$runtime_json"; then
      emit_failed read-recent-completed state_write_failed
    fi
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-recent-completed "$failure_class"
  fi

  if adapter_run "$stdout_file" "$stderr_file" completed-info; then
    local current runtime summary previous_obs runtime_json
    current="$(cat "$stdout_file")"
    runtime="$(state_read_runtime)"
    previous_obs="$(jq -r '.read_recent_completed.last_observed_at // empty' <<<"$runtime")"
    summary="$(jq -nc \
      --argjson current "$current" \
      --argjson previous "$(jq -c '.read_recent_completed.last_completed_info // null' <<<"$runtime")" '
        def to_map(arr): reduce (arr // [])[] as $item ({};
          .[
            if ($item.project_id // null) != null then "project:" + $item.project_id
            elif ($item.section_id // null) != null then "section:" + $item.section_id
            elif ($item.item_id // null) != null then "item:" + $item.item_id
            else "unknown"
            end
          ] = ($item.completed_items // 0)
        );
        ($current.completed_info // []) as $curr_arr
        | ($previous.completed_info // []) as $prev_arr
        | (to_map($curr_arr)) as $curr_map
        | (to_map($prev_arr)) as $prev_map
        | {
            baseline_present: ($previous != null),
            delta_completed_items_total: (reduce ($curr_map | keys[]) as $k (0; . + ((($curr_map[$k] // 0) - ($prev_map[$k] // 0)) | if . > 0 then . else 0 end))),
            observed_bucket_count: ($curr_arr | length)
          }
      ')"
    runtime_json="$(jq -c --arg ts "$ts" --argjson current "$current" --argjson summary "$summary" --arg prev "$previous_obs" '
      .read_recent_completed.last_completed_info = $current
      | .read_recent_completed.last_summary = $summary
      | .read_recent_completed.previous_observed_at = (if $prev == "" then null else $prev end)
      | .read_recent_completed.last_observed_at = $ts
      | .last_verified_at = $ts
      | .last_failure_class = null
    ' <<<"$runtime")"
    if ! state_write_runtime "$runtime_json"; then
      emit_failed read-recent-completed state_write_failed
    fi
    json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-recent-completed --arg status ok --arg source live --arg observed_at "$ts" --arg previous_observed_at "$previous_obs" --arg note 'Bounded observational summary derived from a live aggregate read. Completed task bodies are not cached by contract.' --arg provenance runtime-metadata-summary --argjson summary "$summary" '
      {contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,summary:$summary,note:$note,provenance:$provenance}
      + (if $previous_observed_at == "" then {} else {previous_observed_at:$previous_observed_at} end)')"
    cleanup_files "$stdout_file" "$stderr_file"
    return 0
  fi

  local adapter_status failure_class runtime summary last_observed_at previous_observed_at runtime_json
  adapter_status=$?
  failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
  runtime="$(state_read_runtime)"
  summary="$(jq -c '.read_recent_completed.last_summary // null' <<<"$runtime")"
  last_observed_at="$(jq -r '.read_recent_completed.last_observed_at // empty' <<<"$runtime")"
  previous_observed_at="$(jq -r '.read_recent_completed.previous_observed_at // empty' <<<"$runtime")"
  runtime_json="$(jq -c --arg ts "$ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts' <<<"$runtime")"
  if ! state_write_runtime "$runtime_json"; then
    emit_failed read-recent-completed state_write_failed
  fi
  if [[ "$summary" == "null" || -z "$last_observed_at" ]]; then
    emit_failed read-recent-completed "$failure_class"
  fi
  json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-recent-completed --arg status degraded --arg source observational --arg observed_at "$last_observed_at" --arg previous_observed_at "$previous_observed_at" --arg note 'Live completion read failed; returning last bounded observational summary from runtime metadata.' --arg provenance runtime-metadata-summary --argjson summary "$summary" '
      {contract_version:$contract_version,command:$command,status:$status,source:$source,observed_at:$observed_at,summary:$summary,note:$note,provenance:$provenance}
      + (if $previous_observed_at == "" then {} else {previous_observed_at:$previous_observed_at} end)')"
  cleanup_files "$stdout_file" "$stderr_file"
}

read_due_window_command() {
  local from_date="" to_date="" ts stdout_file stderr_file
  while (($#)); do
    case "$1" in
      --from)
        require_option_value read-due-window "${2:-}"
        from_date="${2:-}"
        shift 2
        ;;
      --to)
        require_option_value read-due-window "${2:-}"
        to_date="${2:-}"
        shift 2
        ;;
      *)
        emit_failed read-due-window invalid_argument
        ;;
    esac
  done
  if [[ -z "$from_date" || -z "$to_date" ]]; then
    emit_failed read-due-window invalid_argument
  fi
  if ! valid_date_ymd "$from_date" || ! valid_date_ymd "$to_date" || [[ "$from_date" > "$to_date" ]]; then
    emit_failed read-due-window invalid_argument
  fi

  ts="$(now_utc)"
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  if adapter_run "$stdout_file" "$stderr_file" due-window "$from_date" "$to_date" 200; then
    local tasks runtime_json
    if ! assert_complete_window < "$stdout_file" 2>/dev/null; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-due-window provider_shape_invalid
    fi
    if ! tasks="$(normalize_active_tasks < "$stdout_file" 2>/dev/null)"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-due-window provider_shape_invalid
    fi
    runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
    if ! state_write_runtime "$runtime_json"; then
      cleanup_files "$stdout_file" "$stderr_file"
      emit_failed read-due-window state_write_failed
    fi
    json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-due-window --arg status ok --arg source live --arg checked_at "$ts" --arg from "$from_date" --arg to "$to_date" --argjson tasks "$tasks" '{contract_version:$contract_version,command:$command,status:$status,source:$source,checked_at:$checked_at,from:$from,to:$to,tasks:$tasks,summary:{task_count:($tasks|length)},complete:true}')"
    cleanup_files "$stdout_file" "$stderr_file"
    return 0
  fi

  local adapter_status failure_class
  adapter_status=$?
  failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
  update_runtime_failure "$failure_class" || true
  cleanup_files "$stdout_file" "$stderr_file"
  emit_failed read-due-window "$failure_class"
}

explain_degraded_state_command() {
  ensure_state_file
  if [[ ! -r "$STATE_FILE" ]]; then
    emit_failed explain-degraded-state state_read_failed
  fi
  if ! jq empty "$STATE_FILE" >/dev/null 2>&1; then
    emit_failed explain-degraded-state state_corrupt
  fi
  local runtime last_verified_at last_failure_class guidance
  runtime="$(state_read_runtime 2>/dev/null || true)"
  if [[ -z "$runtime" ]]; then
    emit_failed explain-degraded-state state_invalid
  fi
  last_verified_at="$(jq -r '.last_verified_at // empty' <<<"$runtime")"
  last_failure_class="$(jq -r '.last_failure_class // empty' <<<"$runtime")"
  guidance="If live Todoist access is degraded, continue with bounded continuity only and do not treat local metadata as task truth."
  json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command explain-degraded-state --arg status ok --arg guidance "$guidance" --arg provenance runtime-metadata --arg last_verified_at "$last_verified_at" --arg last_failure_class "$last_failure_class" '
    {contract_version:$contract_version,command:$command,status:$status,guidance:$guidance,provenance:$provenance}
    + (if $last_verified_at == "" then {last_verified_at:null} else {last_verified_at:$last_verified_at} end)
    + (if $last_failure_class == "" then {} else {last_failure_class:$last_failure_class} end)')"
}

classify_interaction_signals_command() {
  if (($#)); then
    emit_failed classify-interaction-signals invalid_argument
  fi

  local checked_at runtime signals summary note
  checked_at="$(now_utc)"
  note="Metadata-only classification of already-observed Todoist runtime signals. This command does not call Todoist, mutate runtime state, cache task bodies, or create a canonical event stream."

  if [[ ! -e "$STATE_FILE" ]]; then
    runtime='{}'
  else
    if [[ ! -r "$STATE_FILE" ]]; then
      emit_failed classify-interaction-signals state_read_failed
    fi
    if [[ ! -s "$STATE_FILE" ]]; then
      emit_failed classify-interaction-signals state_corrupt
    fi
    if ! jq empty "$STATE_FILE" >/dev/null 2>&1; then
      emit_failed classify-interaction-signals state_corrupt
    fi
    if ! runtime="$(jq -c '
      if (.todoist.runtime? == null) then {}
      elif ((.todoist.runtime | type) == "object") then .todoist.runtime
      else error("state_invalid")
      end
    ' "$STATE_FILE" 2>/dev/null)"; then
      emit_failed classify-interaction-signals state_invalid
    fi
    if [[ -z "$runtime" ]]; then
      emit_failed classify-interaction-signals state_corrupt
    fi
  fi

  signals="$(jq -c '
    def completion_signal:
      (.read_recent_completed.last_summary // null) as $summary
      | (.read_recent_completed.last_observed_at // null) as $observed_at
      | if (($summary | type) == "object" and (($summary.delta_completed_items_total // 0) > 0)) then
          [{
            signal_id: ("runtime-completion-delta:" + ($observed_at // "unknown")),
            level: "aggregated",
            reason: "recent_completed_delta_observed",
            confidence: "medium",
            source_event_kind: "completed-info-delta",
            observed_at: $observed_at,
            source: "runtime-metadata",
            requires_user_interruption: false,
            semantic: {
              delta_completed_items_total: ($summary.delta_completed_items_total // 0),
              observed_bucket_count: ($summary.observed_bucket_count // 0),
              baseline_present: ($summary.baseline_present // false)
            }
          }]
        else [] end;
    def degradation_signal:
      (.last_failure_class // null) as $failure_class
      | (.last_failure_at // null) as $observed_at
      | if ($failure_class != null and $failure_class != "") then
          [{
            signal_id: ("runtime-degradation:" + $failure_class + ":" + ($observed_at // "unknown")),
            level: "observed",
            reason: "todoist_runtime_degraded",
            confidence: "high",
            source_event_kind: "runtime-failure",
            observed_at: $observed_at,
            source: "runtime-metadata",
            requires_user_interruption: false,
            semantic: {
              failure_class: $failure_class
            }
          }]
        else [] end;
    completion_signal + degradation_signal
  ' <<<"$runtime")"
  summary="$(jq -c '{signal_count:length, attention_worthy_count:(map(select(.level == "attention-worthy")) | length), action_eligible_count:(map(select(.level == "action-eligible")) | length)}' <<<"$signals")"

  json_out "$(jq -nc \
    --arg contract_version "$CONTRACT_VERSION" \
    --arg command classify-interaction-signals \
    --arg status ok \
    --arg source runtime-metadata \
    --arg checked_at "$checked_at" \
    --arg note "$note" \
    --argjson signals "$signals" \
    --argjson summary "$summary" \
    '{contract_version:$contract_version,command:$command,status:$status,source:$source,checked_at:$checked_at,signals:$signals,summary:$summary,complete:true,note:$note}')"
}

main() {
  local command="${1:-}"
  shift || true
  case "$command" in
    health) health_command ;;
    read-projects|projects) read_projects_command ;;
    read-active) read_active_command ;;
    capture-task) capture_task_command "$@" ;;
    complete-task) task_completion_command complete-task close-task "$@" ;;
    reopen-task) task_completion_command reopen-task reopen-task "$@" ;;
    update-due) update_due_command "$@" ;;
    update-deadline) update_deadline_command "$@" ;;
    clear-deadline) clear_deadline_command "$@" ;;
    update-labels) update_labels_command "$@" ;;
    update-content) update_content_command "$@" ;;
    update-priority) update_priority_command "$@" ;;
    update-description) update_description_command "$@" ;;
    move-task) move_task_command "$@" ;;
    read-recent-completed) read_recent_completed_command "$@" ;;
    read-recent-activity) read_recent_activity_command "$@" ;;
    read-activity-log) read_activity_log_command "$@" ;;
    ensure-observation-baseline) ensure_observation_baseline_command "$@" ;;
    read-recent-diff) read_recent_diff_command "$@" ;;
    read-due-window) read_due_window_command "$@" ;;
    explain-degraded-state) explain_degraded_state_command ;;
    classify-interaction-signals) classify_interaction_signals_command "$@" ;;
    *) emit_failed unknown-command invalid_argument ;;
  esac
}

main "$@"
