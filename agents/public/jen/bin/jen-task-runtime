        description_seen=true
        shift 2
        ;;
      *)
        emit_failed update-description invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || "$description_seen" != true ]]; then
    emit_failed update-description invalid_argument
  fi

