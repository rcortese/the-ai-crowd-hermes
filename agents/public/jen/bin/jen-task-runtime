#!/usr/bin/env bash
set -euo pipefail

CONTRACT_VERSION="jen-task-runtime.v1"
AUTHORITY="workspace-todoist-adapter"
WORKSPACE_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
STATE_FILE="${JEN_TASK_RUNTIME_STATE_FILE:-/opt/data/state/jen/heartbeat-state.json}"
TODOIST_SCRIPT="${JEN_TASK_RUNTIME_TODOIST_SCRIPT:-$WORKSPACE_ROOT/tools/todoist/todoist-api.sh}"
TODOIST_ENV_FILE="${TODOIST_ENV_FILE:-/opt/data/.env}"
MUTATION_HELPER="${JEN_TASK_RUNTIME_MUTATION_HELPER:-$WORKSPACE_ROOT/bin/jen-mutation-runtime-helper}"
OBSERVATION_STATE_FILE="${JEN_TODOIST_OBSERVATION_STATE_FILE:-/opt/data/state/jen/todoist-observation-snapshot.json}"

now_utc() {
  if [[ -n "${JEN_TASK_RUNTIME_NOW_UTC:-}" ]]; then
    printf '%s
' "$JEN_TASK_RUNTIME_NOW_UTC"
  else
    date -u +"%Y-%m-%dT%H:%M:%SZ"
  fi
}

json_out() {
  printf '%s\n' "$1"
}

cleanup_files() {
  local path
  for path in "$@"; do
    [[ -n "$path" ]] && rm -f "$path"
  done
}

require_bin() {
  command -v "$1" >/dev/null 2>&1
}

ensure_parent_dir() {
  mkdir -p "$(dirname "$STATE_FILE")"
}

ensure_state_file() {
  ensure_parent_dir
  if [[ -f "$STATE_FILE" && -s "$STATE_FILE" ]] && jq empty "$STATE_FILE" >/dev/null 2>&1; then
    return 0
  fi

  local tmp
  tmp=$(mktemp)
  cat > "$tmp" <<'EOF'
{
  "dailyPass": {
    "morning": {
      "date": null,
      "outcome": null,
      "deliveredAt": null,
      "restartPoint": null
    },
    "dayClose": {
      "date": null,
      "outcome": null,
      "deliveredAt": null,
      "restartPoint": null
    }
  },
  "todoist": {
    "runtime": {
      "notes": "Runtime-owned metadata only. Not task truth.",
      "last_verified_at": null,
      "last_failure_class": null,
      "read_recent_completed": {
        "last_completed_info": null,
        "last_summary": null,
        "last_observed_at": null,
        "previous_observed_at": null,
        "last_task_window": null
      },
      "read_recent_activity": {
        "last_activity_window": null
      },
      "read_activity_log": {
        "last_activity_window": null
      },
      "read_recent_diff": {
        "last_diff_window": null
      }
    }
  },
  "notes": "Minimal automation state for duplicate suppression and restart continuity only. Not a planning source of truth."
}
EOF
  mv "$tmp" "$STATE_FILE"
}

state_read_json() {
  ensure_state_file
  cat "$STATE_FILE"
}

state_read_runtime() {
  ensure_state_file
  jq -c '.todoist.runtime // {}' "$STATE_FILE"
}

state_write_runtime() {
  local runtime_json="$1"
  ensure_state_file
  local tmp
  tmp=$(mktemp)
  if ! jq --argjson runtime "$runtime_json" '.todoist = (.todoist // {}) | .todoist.runtime = $runtime' "$STATE_FILE" > "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$STATE_FILE"
}

ensure_observation_parent_dir() {
  mkdir -p "$(dirname "$OBSERVATION_STATE_FILE")"
}

read_observation_snapshot() {
  if [[ -f "$OBSERVATION_STATE_FILE" && -s "$OBSERVATION_STATE_FILE" ]] && jq empty "$OBSERVATION_STATE_FILE" >/dev/null 2>&1; then
    cat "$OBSERVATION_STATE_FILE"
  else
    printf 'null
'
  fi
}

write_observation_snapshot() {
  local snapshot_json="$1"
  ensure_observation_parent_dir
  local tmp
  tmp=$(mktemp "$(dirname "$OBSERVATION_STATE_FILE")/.todoist-observation-snapshot.XXXXXX")
  if ! jq -c . <<<"$snapshot_json" > "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  mv "$tmp" "$OBSERVATION_STATE_FILE"
}

valid_ttl_hours() {
  [[ "${1:-}" =~ ^[0-9]+$ ]] && [[ "$1" -ge 1 && "$1" -le 168 ]]
}

snapshot_is_valid() {
  local snapshot_json="$1"
  [[ "$snapshot_json" != "null" ]] && jq -e '(.contract_version == "jen-todoist-observation-snapshot.v1") and ((.tasks|type)=="array") and (.observed_at|type)=="string"' <<<"$snapshot_json" >/dev/null 2>&1
}

snapshot_age_seconds() {
  local observed_at="$1" now_ts="$2" observed_epoch now_epoch
  observed_epoch="$(rfc3339_epoch "$observed_at")" || return 1
  now_epoch="$(rfc3339_epoch "$now_ts")" || return 1
  printf '%s
' $(( now_epoch - observed_epoch ))
}

build_observation_snapshot_json() {
  local observed_at="$1" tasks_json="$2" limit="$3" ttl_hours="$4" task_count
  task_count="$(jq 'length' <<<"$tasks_json")"
  jq -nc     --arg observed_at "$observed_at"     --arg source live-active-observation     --arg schema_version 1     --argjson task_count "$task_count"     --argjson tasks "$tasks_json"     --argjson limit "$limit"     --argjson ttl_hours "$ttl_hours"     '{contract_version:"jen-todoist-observation-snapshot.v1",schema_version:($schema_version|tonumber),observed_at:$observed_at,source:$source,task_count:$task_count,limit:$limit,ttl_hours:$ttl_hours,truncated:false,tasks:$tasks}'
}

runtime_with_updates() {
  local patch_filter="${*: -1}"
  local jq_args=()
  if (($# > 1)); then
    jq_args=("${@:1:$#-1}")
  fi
  local runtime_json
  runtime_json="$(state_read_runtime | jq -c "${jq_args[@]}" "$patch_filter")"
  printf '%s' "$runtime_json"
}

emit_failed() {
  local command="$1"
  local failure_class="$2"
  local extra_json="${3:-{}}"
  local merged
  if ! merged="$(python3 - "$CONTRACT_VERSION" "$command" "$failure_class" "$extra_json" <<'PY'
import json, sys
contract_version, command, failure_class, extra_raw = sys.argv[1:5]
base = {
    "contract_version": contract_version,
    "command": command,
    "status": "failed",
    "failure_class": failure_class,
}
try:
    extra = json.loads(extra_raw or "{}")
    if isinstance(extra, dict):
        base.update(extra)
except Exception:
    pass
base.update({
    "contract_version": contract_version,
    "command": command,
    "status": "failed",
    "failure_class": failure_class,
})
print(json.dumps(base, separators=(",", ":")))
PY
  )"; then
    merged="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg runtime_command "$command" --arg status failed --arg failure_class "$failure_class" '{contract_version:$contract_version,command:$runtime_command,status:$status,failure_class:$failure_class}')"
  fi
  json_out "$merged"
  exit 1
}

require_option_value() {
  local command="$1"
  local value="${2:-}"
  if [[ -z "$value" || "$value" == --* ]]; then
    emit_failed "$command" invalid_argument
  fi
}

valid_date_ymd() {
  [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] && [[ "$(date -u -d "$1" +%F 2>/dev/null || true)" == "$1" ]]
}

normalize_due_phrase_json() {
  local raw_due="$1" base_date="${2:-}"
  [[ -n "$base_date" ]] || base_date="$(date -u -d "$(now_utc)" +%F 2>/dev/null || true)"
  [[ -n "$base_date" ]] || return 1
  python3 - "$raw_due" "$base_date" <<'PY'
import datetime as dt
import json
import re
import sys
import unicodedata

raw_due = sys.argv[1].strip()
base_date_raw = sys.argv[2]

def canonical(text: str) -> str:
    text = unicodedata.normalize('NFKD', text or '').encode('ascii', 'ignore').decode('ascii')
    text = text.lower().strip().replace('_', ' ')
    text = re.sub(r'[-]+', ' ', text)
    text = re.sub(r'[^\w\s]+', ' ', text)
    text = re.sub(r'\s+', ' ', text)
    return text

def valid_date(text: str) -> bool:
    try:
        return dt.date.fromisoformat(text).isoformat() == text
    except ValueError:
        return False

def next_weekday(base: dt.date, weekday: int) -> str:
    offset = (weekday - base.weekday()) % 7
    if offset == 0:
        offset = 7
    return (base + dt.timedelta(days=offset)).isoformat()

try:
    base_date = dt.date.fromisoformat(base_date_raw)
except ValueError:
    raise SystemExit(1)

canon = canonical(raw_due)
weekday_aliases = {
    0: {'monday', 'mon', 'segunda', 'segunda feira', 'seg', '2a feira'},
    1: {'tuesday', 'tue', 'tues', 'terca', 'terca feira', 'ter', '3a feira'},
    2: {'wednesday', 'wed', 'quarta', 'quarta feira', 'qua', '4a feira'},
    3: {'thursday', 'thu', 'thur', 'thurs', 'quinta', 'quinta feira', 'qui', '5a feira'},
    4: {'friday', 'fri', 'sexta', 'sexta feira', 'sex', '6a feira'},
    5: {'saturday', 'sat', 'sabado', 'sab'},
    6: {'sunday', 'sun', 'domingo', 'dom'},
}
ambiguous_standalone_ordinals = {'2a', '3a', '4a', '5a', '6a'}
weekday_map = {
    alias: weekday
    for weekday, aliases in weekday_aliases.items()
    for alias in aliases
}
relative_prefixes = ('next ', 'proxima ', 'proximo ', 'prox ')

recognized = False
ambiguous = False
normalized_due = raw_due
target_date = None

if valid_date(raw_due):
    recognized = True
    normalized_due = raw_due
    target_date = raw_due
elif canon in {'today', 'hoje'}:
    recognized = True
    normalized_due = 'today'
    target_date = base_date.isoformat()
elif canon in {'tomorrow', 'amanha'}:
    recognized = True
    normalized_due = 'tomorrow'
    target_date = (base_date + dt.timedelta(days=1)).isoformat()
elif canon in {'day after tomorrow', 'depois de amanha'}:
    recognized = True
    normalized_due = (base_date + dt.timedelta(days=2)).isoformat()
    target_date = normalized_due
else:
    lookup = canon
    for prefix in relative_prefixes:
        if lookup.startswith(prefix):
            lookup = lookup[len(prefix):].strip()
            break
    if lookup in ambiguous_standalone_ordinals:
        ambiguous = True
    else:
        weekday = weekday_map.get(lookup)
        if weekday is not None:
            recognized = True
            normalized_due = next_weekday(base_date, weekday)
            target_date = normalized_due

print(json.dumps({
    'recognized': recognized,
    'ambiguous': ambiguous,
    'raw_due': raw_due,
    'canonical': canon,
    'normalized_due': normalized_due,
    'target_date': target_date,
}, ensure_ascii=False))
PY
}

normalize_due_string_if_supported() {
  local due_string="$1" base_date="${2:-}" due_json normalized_due ambiguous
  due_json="$(normalize_due_phrase_json "$due_string" "$base_date")" || return 1
  ambiguous="$(jq -r '.ambiguous // false' <<<"$due_json")"
  if [[ "$ambiguous" == "true" ]]; then
    return 2
  fi
  normalized_due="$(jq -r '.normalized_due // empty' <<<"$due_json")"
  if [[ -n "$normalized_due" ]]; then
    printf '%s\n' "$normalized_due"
  else
    printf '%s\n' "$due_string"
  fi
}

valid_rfc3339_utc() {
  [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]] && date -u -d "$1" +%Y-%m-%dT%H:%M:%SZ >/dev/null 2>&1
}

rfc3339_epoch() {
  date -u -d "$1" +%s 2>/dev/null || return 1
}

valid_since_until() {
  local since="$1" until="$2" since_epoch until_epoch
  valid_rfc3339_utc "$since" || return 1
  valid_rfc3339_utc "$until" || return 1
  since_epoch="$(rfc3339_epoch "$since")" || return 1
  until_epoch="$(rfc3339_epoch "$until")" || return 1
  [[ "$since_epoch" -le "$until_epoch" ]]
}

valid_limit() {
  [[ "${1:-}" =~ ^[0-9]+$ ]] && [[ "$1" -ge 1 && "$1" -le 200 ]]
}

map_adapter_error_class() {
  local stderr_file="$1"
  local adapter_status="$2"
  local raw error
  raw="$(cat "$stderr_file" 2>/dev/null || true)"
  error="$(jq -r 'first(.error? // empty)' <<<"$raw" 2>/dev/null || true)"
  case "$error" in
    missing_dependency) echo missing_dependency ;;
    missing_token) echo missing_token ;;
    auth_failure) echo auth_failure ;;
    network_failure) echo network_failure ;;
    rate_limited) echo rate_limited ;;
    verification_failed) echo verification_failed ;;
    request_failed|server_error|not_found) echo request_failure ;;
    provider_shape_invalid) echo provider_shape_invalid ;;
    missing_argument:*|invalid_limit|limit_out_of_range|invalid_deadline_date) echo invalid_argument ;;
    *)
      case "$adapter_status" in
        127) echo adapter_missing ;;
        2) echo request_failure ;;
        3) echo network_failure ;;
        4) echo request_failure ;;
        5) echo verification_failed ;;
        *) echo request_failure ;;
      esac
      ;;
  esac
}

mutation_helper_run() {
  if [[ ! -x "$MUTATION_HELPER" ]]; then
    return 127
  fi
  "$MUTATION_HELPER" "$@"
}

mutation_draft_task_create() {
  local content="$1"
  local due_string="$2"
  jq -nc --arg content "$content" --arg due_string "$due_string" '
    {
      user_request_ref: ("jen-task-runtime:capture-task:" + $content + ":" + $due_string),
      operation_type: "create",
      target_system: "todoist",
      canonical_object_type: "task",
      mutation_payload: ({content:$content} + (if $due_string != "" then {due_string:$due_string} else {} end)),
      preview: {
        human_summary: (if $due_string != "" then "Create Todoist task with due date" else "Create Todoist task" end),
        fields_changed: (["content"] + (if $due_string != "" then ["due_string"] else [] end)),
        expected_effect: "Todoist task capture"
      }
    }
  '
}

mutation_draft_task_due_update() {
  local task_id="$1"
  local due_string="$2"
  local pre_state_json="$3"
  jq -nc --arg task_id "$task_id" --arg due_string "$due_string" --argjson pre_state "$pre_state_json" '
    {
      user_request_ref: ("jen-task-runtime:update-due:" + $task_id + ":" + $due_string),
      operation_type: "update",
      target_system: "todoist",
      canonical_object_type: "task",
      external_object_id: $task_id,
      pre_state: $pre_state,
      mutation_payload: {due_string:$due_string},
      requires_confirmation: false,
      preview: {
        human_summary: "Update Todoist task due date",
        fields_changed: ["due_string"],
        expected_effect: "Todoist task due date update"
      }
    }
    | if (($pre_state.due.is_recurring // false) == true)
      then .canonical_object_type = "recurring_task" | .mutation_payload.recurring = true
      else .
      end
  '
}

