mutation_draft_task_completion_change() {
  local task_id="$1"
  local action="$2"
  local pre_state_json="$3"
  local idempotency_hint="${4:-}"
  local confirmed_by_user="${5:-false}"
  local operation_type completed human_summary expected_effect
  case "$action" in
    complete)
      operation_type="complete"
      completed=true
      human_summary="Complete Todoist task"
      expected_effect="Todoist task completion"
      ;;
    reopen)
      operation_type="update"
      completed=false
      human_summary="Reopen Todoist task"
      expected_effect="Todoist task reopen"
      ;;
    *)
      emit_failed unknown-command invalid_argument
      ;;
  esac
  jq -nc \
    --arg task_id "$task_id" \
    --arg action "$action" \
    --arg idempotency_hint "$idempotency_hint" \
    --arg operation_type "$operation_type" \
    --arg human_summary "$human_summary" \
    --arg expected_effect "$expected_effect" \
    --argjson confirmed_by_user "$confirmed_by_user" \
    --argjson completed "$completed" \
    --argjson pre_state "$pre_state_json" '
    {
      user_request_ref: ("jen-task-runtime:" + $action + "-task:" + $task_id + (if $idempotency_hint != "" then ":" + $idempotency_hint else "" end)),
      operation_type: $operation_type,
      target_system: "todoist",
      canonical_object_type: "task",
      external_object_id: $task_id,
      pre_state: $pre_state,
      requires_confirmation: ($confirmed_by_user | not),
      mutation_payload: {completed:$completed, scope:"single", confirmed_by_user:$confirmed_by_user},
      preview: {
        human_summary: $human_summary,
        fields_changed: ["completed"],
        expected_effect: $expected_effect
      }
    }
    | if (($pre_state.due.is_recurring // false) == true)
      then .canonical_object_type = "recurring_task" | .mutation_payload.recurring = true
      else .
      end
  '
}

mutation_draft_task_project_move() {
  local task_id="$1"
  local project_id="$2"
  local pre_state_json="$3"
  jq -nc --arg task_id "$task_id" --arg project_id "$project_id" --argjson pre_state "$pre_state_json" '
    {
      user_request_ref: ("jen-task-runtime:move-task:" + $task_id + ":" + $project_id),
      operation_type: "update",
      target_system: "todoist",
      canonical_object_type: "task",
      external_object_id: $task_id,
      pre_state: $pre_state,
      mutation_payload: {project_id:$project_id},
      preview: {
        human_summary: "Move Todoist task to another project/list",
        fields_changed: ["project_id"],
        expected_effect: "Todoist task project/list move"
      }
    }
  '
}

mutation_record_payload() {
  local plan_json="$1"
  local status="$2"
  local result_json="$3"
  jq -nc --argjson plan "$plan_json" --argjson result "$result_json" '$plan + {result:$result}'
}

mutation_record_status() {
  local plan_json="$1"
  local status="$2"
  local result_json="$3"
  local payload
  payload="$(mutation_record_payload "$plan_json" "$status" "$result_json")"
  mutation_helper_run record --status "$status" - <<<"$payload" >/dev/null
}

adapter_run() {
  local stdout_file="$1"
  local stderr_file="$2"
  shift 2
  local -a cmd=("$TODOIST_SCRIPT" "$@")
  if [[ ! -x "$TODOIST_SCRIPT" ]]; then
    return 127
  fi
  if [[ -z "${TODOIST_API_TOKEN:-}" && -f "$TODOIST_ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$TODOIST_ENV_FILE"
  fi
  set +e
  "${cmd[@]}" >"$stdout_file" 2>"$stderr_file"
  local status=$?
  set -e
  return "$status"
}

update_runtime_failure() {
  local failure_class="$1"
  local current_ts
  current_ts="$(now_utc)"
  local runtime_json
  runtime_json="$(runtime_with_updates --arg ts "$current_ts" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts')"
  state_write_runtime "$runtime_json"
}

update_runtime_success() {
  local current_ts="$1"
  local runtime_json
  runtime_json="$(runtime_with_updates --arg ts "$current_ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json"
}

health_command() {
  local status posture token_status
  token_status=missing
  if [[ -n "${TODOIST_API_TOKEN:-}" ]]; then
    token_status=set
  elif [[ -f "$TODOIST_ENV_FILE" ]] && grep -q '^TODOIST_API_TOKEN=' "$TODOIST_ENV_FILE"; then
    token_status=set
  fi

  if [[ -x "$TODOIST_SCRIPT" ]] && require_bin curl && require_bin jq && require_bin python3 && [[ "$token_status" == set ]]; then
    status=ok
    posture=available
  elif [[ ! -x "$TODOIST_SCRIPT" ]]; then
    status=unavailable
    posture=unavailable
  else
    status=degraded
    posture=degraded
  fi

  json_out "$(jq -nc \
    --arg contract_version "$CONTRACT_VERSION" \
    --arg command health \
    --arg status "$status" \
    --arg posture "$posture" \
    --arg authority "$AUTHORITY" \
    --arg adapter_path "$TODOIST_SCRIPT" \
    --arg token_status "$token_status" \
    --arg checked_at "$(now_utc)" \
    '{contract_version:$contract_version,command:$command,status:$status,posture:$posture,authority:$authority,adapter_path:$adapter_path,token_status:$token_status,checked_at:$checked_at}')"
}

read_projects_command() {
  local ts stdout_file stderr_file adapter_status failure_class runtime_json projects_json
  ts="$(now_utc)"
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  adapter_status=0
  adapter_run "$stdout_file" "$stderr_file" projects || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed read-projects state_write_failed
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-projects "$failure_class"
  fi

  if ! projects_json="$(jq -c '[.results[]? | {id:(.id|tostring), name, order:(.order // null), parent_id:((.parent_id // null) | if . == null then null else tostring end), is_archived:(.is_archived // false), is_favorite:(.is_favorite // false)}]' "$stdout_file")"; then
    runtime_json="$(runtime_with_updates --arg fc provider_shape_invalid --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed read-projects state_write_failed
    cleanup_files "$stdout_file" "$stderr_file"
    emit_failed read-projects provider_shape_invalid
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed read-projects state_write_failed
  json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-projects --arg status ok --arg source live --arg checked_at "$ts" --argjson projects "$projects_json" '{contract_version:$contract_version,command:$command,status:$status,source:$source,checked_at:$checked_at,projects:$projects,summary:{project_count:($projects|length)},complete:true}')"
  cleanup_files "$stdout_file" "$stderr_file"
}

normalize_active_tasks() {
  jq -c '
    def normalized_task:
      {
        id: (.id // null),
        content: (.content // null),
        description: (.description // null),
        project_id: (.project_id // null),
        section_id: (.section_id // null),
        parent_id: (.parent_id // null),
        labels: (if (.labels | type) == "array" then .labels else [] end),
        due: (if (.due | type) == "object" then .due else null end),
        deadline: (if (.deadline | type) == "object" then .deadline else null end),
        priority: (if (.priority | type) == "number" then .priority else null end),
        updated_at: (.updated_at // null),
        source: "live"
      };
    if type == "array" then
      map(normalized_task)
    elif ((type == "object") and ((.results? | type) == "array")) then
      .results | map(normalized_task)
    else
      error("provider_shape_invalid")
    end
  '
}

normalize_snapshot_tasks() {
  jq -c '
    def normalized_task:
      {
        id: ((.id // null) | if . == null then null else tostring end),
        content: (.content // null),
        description: (.description // null),
        project_id: ((.project_id // null) | if . == null then null else tostring end),
        section_id: ((.section_id // null) | if . == null then null else tostring end),
        parent_id: ((.parent_id // null) | if . == null then null else tostring end),
        labels: (if (.labels | type) == "array" then (.labels | map(tostring) | sort) else [] end),
        due: (if (.due | type) == "object" then .due else null end),
        priority: (if (.priority | type) == "number" then .priority else null end),
        updated_at: (.updated_at // null)
      } + (if has("deadline") then {deadline:.deadline} else {} end);
    if type == "array" then
      map(normalized_task | select(.id != null)) | sort_by(.id)
    elif ((type == "object") and ((.results? | type) == "array")) then
      .results | map(normalized_task | select(.id != null)) | sort_by(.id)
    else
      error("provider_shape_invalid")
    end
  '
}

build_observation_diff() {
  local baseline_tasks="$1"
  local current_tasks="$2"
  jq -nc --argjson baseline "$baseline_tasks" --argjson current "$current_tasks" '
    def by_id(arr): reduce arr[] as $t ({}; .[$t.id] = $t);
    def changed_fields($before; $after):
      ["content","description","project_id","section_id","parent_id","labels","due","priority","updated_at","deadline"]
      | map(select(($before[.] // null) != ($after[.] // null)));
    (by_id($baseline)) as $b
    | (by_id($current)) as $c
    | (($b|keys_unsorted) - ($c|keys_unsorted)) as $removed_ids
    | (($c|keys_unsorted) - ($b|keys_unsorted)) as $added_ids
    | (($b|keys_unsorted) as $bk | ($c|keys_unsorted) as $ck | $bk - ($bk - $ck)) as $common_ids
    | {
        changed: [ $common_ids[] as $id | (changed_fields($b[$id]; $c[$id])) as $fields | select($fields|length>0) | {id:$id,change_type:"changed_active_observation",changed_fields:$fields,before:$b[$id],after:$c[$id]} ],
        added_to_active_observation: [ $added_ids[] as $id | $c[$id] ],
        removed_from_active_observation: [ $removed_ids[] as $id | $b[$id] ]
      }
  '
}

assert_complete_window() {
  jq -e '((.complete == true) and ((.next_cursor // null) == null))' >/dev/null
}

normalize_completed_tasks() {
  jq -c '
    def normalized_completed_task:
      {
        id: (.id // null),
        content: (.content // null),
        description: (.description // null),
        project_id: (.project_id // null),
        section_id: (.section_id // null),
        parent_id: (.parent_id // null),
        labels: (if (.labels | type) == "array" then .labels else [] end),
        due: (if (.due | type) == "object" then .due else null end),
        deadline: (if (.deadline | type) == "object" then .deadline else null end),
        priority: (if (.priority | type) == "number" then .priority else null end),
        added_at: (.added_at // null),
        completed_at: (.completed_at // null),
        updated_at: (.updated_at // null),
        source: "live"
      };
    if ((type == "object") and ((.items? | type) == "array")) then
      .items | map(normalized_completed_task)
    elif type == "array" then
      map(normalized_completed_task)
    else
      error("provider_shape_invalid")
    end
  '
}

normalize_activity_events() {
  jq -c '
    def event_kind:
      (.object_event_type // .event_type // .event_name // .action // null);
    def normalized_event:
      {
        id: (.id // .event_id // null),
        event_type: (.event_type // .event_name // null),
        object_event_type: (.object_event_type // null),
        object_type: (.object_type // .object_type_name // .object.type // null),
        object_id: ((.object_id // .object.id // .item_id // null) | if . == null then null else tostring end),
        parent_project_id: ((.parent_project_id // .project_id // .parent_project?.id // null) | if . == null then null else tostring end),
        parent_item_id: ((.parent_item_id // .parent_id // null) | if . == null then null else tostring end),
        initiator_id: ((.initiator_id // .user_id // null) | if . == null then null else tostring end),
        event_date: (.event_date // .created_at // .event_time // .timestamp // null),
        extra_data: (if (.extra_data | type) == "object" then .extra_data else {} end),
        source: "live"
      };
    if ((type == "object") and ((.results? | type) == "array")) then
      .results | map(normalized_event)
    elif type == "array" then
      map(normalized_event)
    else
      error("provider_shape_invalid")
    end
  '
}

read_active_degraded_response() {
  local checked_at="$1"
  local failure_class="$2"
  local note runtime_json
  note="Live Todoist read failed; returning degraded metadata-only state. No active task bodies are cached by contract."
  runtime_json="$(runtime_with_updates --arg ts "$checked_at" --arg fc "$failure_class" '.last_failure_class = $fc | .last_failure_at = $ts')"
  if ! state_write_runtime "$runtime_json"; then
    emit_failed read-active state_write_failed
  fi
  json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-active --arg status degraded --arg source degraded-metadata --arg checked_at "$checked_at" --arg note "$note" --arg provenance runtime-metadata '{contract_version:$contract_version,command:$command,status:$status,source:$source,checked_at:$checked_at,note:$note,provenance:$provenance}')"
}

resolve_due_date_for_preflight() {
  local due_string="$1" base_date="${2:-}" due_json target_date
  [[ -n "$base_date" ]] || base_date="$(date -u -d "$(now_utc)" +%F 2>/dev/null || true)"
  [[ -n "$base_date" ]] || return 1
  due_json="$(normalize_due_phrase_json "$due_string" "$base_date")" || return 1
  target_date="$(jq -r '.target_date // empty' <<<"$due_json")"
  [[ -n "$target_date" ]] || return 1
  valid_date_ymd "$target_date" || return 1
  printf '%s\n' "$target_date"
}

semantic_duplicate_preflight() {
  local content="$1" due_string="$2" base_date="${3:-}" active_stdout active_stderr active_tasks due_tasks="[]" target_date="" to_date=""
  active_stdout=$(mktemp)
  active_stderr=$(mktemp)

  if ! adapter_run "$active_stdout" "$active_stderr" active-snapshot 200; then
    cleanup_files "$active_stdout" "$active_stderr"
    jq -nc --arg status unable_to_verify_duplicates --arg reason active_read_failed '{status:$status,reason:$reason}'
    return 0
  fi
  if ! assert_complete_window < "$active_stdout" 2>/dev/null; then
    cleanup_files "$active_stdout" "$active_stderr"
    jq -nc --arg status unable_to_verify_duplicates --arg reason active_read_incomplete '{status:$status,reason:$reason}'
    return 0
  fi
  if ! active_tasks="$(normalize_active_tasks < "$active_stdout" 2>/dev/null)"; then
    cleanup_files "$active_stdout" "$active_stderr"
    jq -nc --arg status unable_to_verify_duplicates --arg reason active_read_degraded '{status:$status,reason:$reason}'
    return 0
  fi
  cleanup_files "$active_stdout" "$active_stderr"

  if [[ -n "$due_string" ]]; then
    if ! target_date="$(resolve_due_date_for_preflight "$due_string" "$base_date")"; then
      jq -nc --arg status unable_to_verify_duplicates --arg reason due_resolution_failed --arg due_string "$due_string" '{status:$status,reason:$reason,due_string:$due_string}'
      return 0
    fi
    to_date="$target_date"
    local due_stdout due_stderr
    due_stdout=$(mktemp)
    due_stderr=$(mktemp)
    if ! adapter_run "$due_stdout" "$due_stderr" due-window "$target_date" "$to_date" 200; then
      cleanup_files "$due_stdout" "$due_stderr"
      jq -nc --arg status unable_to_verify_duplicates --arg reason due_window_read_failed --arg target_date "$target_date" '{status:$status,reason:$reason,target_date:$target_date}'
      return 0
    fi
    if ! assert_complete_window < "$due_stdout" 2>/dev/null; then
      cleanup_files "$due_stdout" "$due_stderr"
      jq -nc --arg status unable_to_verify_duplicates --arg reason due_window_incomplete --arg target_date "$target_date" '{status:$status,reason:$reason,target_date:$target_date}'
      return 0
    fi
    if ! due_tasks="$(normalize_active_tasks < "$due_stdout" 2>/dev/null)"; then
      cleanup_files "$due_stdout" "$due_stderr"
      jq -nc --arg status unable_to_verify_duplicates --arg reason due_window_shape_invalid --arg target_date "$target_date" '{status:$status,reason:$reason,target_date:$target_date}'
      return 0
    fi
    cleanup_files "$due_stdout" "$due_stderr"
  fi

  python3 - "$content" "$due_string" "$target_date" "$active_tasks" "$due_tasks" <<'PY'
import json, re, sys, unicodedata

content, due_string, target_date, active_raw, due_raw = sys.argv[1:6]
active = json.loads(active_raw)
due = json.loads(due_raw)

def norm_tokens(text):
    text = unicodedata.normalize('NFKD', text or '').encode('ascii', 'ignore').decode('ascii').lower()
    text = re.sub(r'[^a-z0-9]+', ' ', text)
    stop = {'a','o','as','os','um','uma','de','do','da','dos','das','no','na','nos','nas','e','para','pra','pro','por','com','em','ao','aos','the','of','for','to','and'}
    tokens = [t for t in text.split() if t and t not in stop]
    out = []
    for token in tokens:
        if len(token) > 4 and token.endswith('s'):
            token = token[:-1]
        out.append(token)
    return out

def due_date(task):
    due = task.get('due')
    if isinstance(due, dict):
        return due.get('date')
    return None

def segments(text):
    parts = [p.strip() for p in re.split(r'\s+e\s+', text or '', flags=re.I) if p.strip()]
    return parts if len(parts) > 1 else [text]

request_tokens = set(norm_tokens(content))
request_segments = [{'text': seg, 'tokens': set(norm_tokens(seg))} for seg in segments(content)]
actionish = {'banho','banhar','cortar','corta','unha','unhas','escovar','dente','dentes','vacina','vacinacao','limpar','comprar','pagar','levar','buscar','marcar','agendar'}
entityish = {t for t in request_tokens if t not in actionish and len(t) > 3}

def segment_entity_overlap(segment_tokens, candidate_tokens):
    segment_entities = {t for t in segment_tokens if t in entityish}
    if not segment_entities:
        return not entityish
    return bool(segment_entities & candidate_tokens)

def classify_task(task, source):
    candidate_tokens = set(norm_tokens(task.get('content')))
    if not candidate_tokens or not request_tokens:
        return None
    intersection = request_tokens & candidate_tokens
    if not intersection:
        return None
    canonical_exact = request_tokens == candidate_tokens
    entity_overlap = bool(entityish & candidate_tokens)
    action_overlap = bool(actionish & intersection) or len(intersection) >= 2
    request_coverage = len(intersection) / max(len(request_tokens), 1)
    candidate_coverage = len(intersection) / max(len(candidate_tokens), 1)
    segment_hits = []
    for segment in request_segments:
        segment_tokens = segment['tokens']
        segment_intersection = segment_tokens & candidate_tokens
        if (
            segment_tokens
            and segment_intersection
            and segment_entity_overlap(segment_tokens, candidate_tokens)
            and ((segment_intersection & actionish) or len(segment_intersection) >= 2)
        ):
            segment_hits.append(segment['text'])
    match_reasons = []
    if canonical_exact:
        match_reasons.append('canonical_tokens_equal_after_stopwords')
    if request_coverage >= 0.8 and candidate_coverage >= 0.8:
        relation = 'duplicate_existing'
        if 'canonical_tokens_equal_after_stopwords' not in match_reasons:
            match_reasons.append('high_bidirectional_token_coverage')
    elif entity_overlap and action_overlap:
        relation = 'semantic_overlap'
        match_reasons.append('entity_and_action_overlap')
    else:
        return None
    existing_due = due_date(task)
    return {
        'id': task.get('id'),
        'content': task.get('content'),
        'due': task.get('due'),
        'source_set': source,
        'relation': relation,
        'match_reasons': match_reasons,
        'due_relation': 'same_due' if target_date and existing_due == target_date else ('different_due' if target_date and existing_due else ('existing_unscheduled' if target_date and not existing_due else 'not_date_bound')),
        'matched_tokens': sorted(intersection),
        'matched_segments': segment_hits,
    }

candidates = []
seen = set()
for source, tasks in [('due-window', due), ('active', active)]:
    for task in tasks:
        candidate = classify_task(task, source)
        if not candidate:
            continue
        key = candidate.get('id') or (candidate.get('content'), source)
        if key in seen:
            continue
        seen.add(key)
        candidates.append(candidate)

if not candidates:
    print(json.dumps({'status':'safe_to_create','target_date':target_date or None,'checked':{'active_task_count':len(active),'due_task_count':len(due)}}, separators=(',', ':')))
elif any(c['relation'] == 'duplicate_existing' for c in candidates):
    print(json.dumps({'status':'duplicate_existing','target_date':target_date or None,'checked':{'active_task_count':len(active),'due_task_count':len(due)},'candidates':candidates}, separators=(',', ':')))
else:
    print(json.dumps({'status':'semantic_duplicate_confirmation_required','target_date':target_date or None,'checked':{'active_task_count':len(active),'due_task_count':len(due)},'candidates':candidates}, separators=(',', ':')))
PY
}

emit_capture_task_preflight_failed() {
  local failure_class="$1"
  local mutation_extra="$2"
  local preflight_json="$3"
  json_out "$(jq -nc \
    --arg contract_version "$CONTRACT_VERSION" \
    --arg runtime_command capture-task \
    --arg failure_class "$failure_class" \
    --argjson extra "$mutation_extra" \
    --argjson preflight "$preflight_json" \
    '{"contract_version":$contract_version,"command":$runtime_command,"status":"failed","failure_class":$failure_class} + $extra + {preflight:$preflight}')"
  exit 1
}

read_active_command() {
  local stdout_file stderr_file checked_at
  checked_at="$(now_utc)"
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)

  if adapter_run "$stdout_file" "$stderr_file" active-snapshot 200; then
    local tasks runtime_json
    if ! assert_complete_window < "$stdout_file" 2>/dev/null; then
      read_active_degraded_response "$checked_at" provider_window_incomplete
      cleanup_files "$stdout_file" "$stderr_file"
      return 0
    fi
    if ! tasks="$(normalize_active_tasks < "$stdout_file" 2>/dev/null)"; then
      read_active_degraded_response "$checked_at" provider_shape_invalid
      cleanup_files "$stdout_file" "$stderr_file"
      return 0
    fi
    runtime_json="$(runtime_with_updates --arg ts "$checked_at" '.last_verified_at = $ts | .last_failure_class = null')"
    if ! state_write_runtime "$runtime_json"; then
      emit_failed read-active state_write_failed
    fi
    json_out "$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command read-active --arg status ok --arg source live --arg checked_at "$checked_at" --argjson tasks "$tasks" '{contract_version:$contract_version,command:$command,status:$status,source:$source,checked_at:$checked_at,tasks:$tasks}')"
    cleanup_files "$stdout_file" "$stderr_file"
    return 0
  fi

  local adapter_status failure_class
  adapter_status=$?
  failure_class="$(map_adapter_error_class "$stderr_file" "$adapter_status")"
  read_active_degraded_response "$checked_at" "$failure_class"
  cleanup_files "$stdout_file" "$stderr_file"
}

capture_task_command() {
  local content="" due_string=""
  while (($#)); do
    case "$1" in
      --content)
        require_option_value capture-task "${2:-}"
        content="${2:-}"
        shift 2
        ;;
      --due)
        require_option_value capture-task "${2:-}"
        due_string="${2:-}"
        shift 2
        ;;
      *)
        emit_failed capture-task invalid_argument
        ;;
    esac
  done

  if [[ -z "$content" ]]; then
    emit_failed capture-task invalid_argument
  fi

  local ts draft_json prepare_json decision gateway_plan mutation_extra command_base_date="" normalized_due_status=0 normalized_due=""
  ts="$(now_utc)"
  if [[ -n "$due_string" ]]; then
    command_base_date="$(date -u -d "$ts" +%F 2>/dev/null || true)"
    [[ -n "$command_base_date" ]] || emit_failed capture-task request_failure
    normalized_due="$(normalize_due_string_if_supported "$due_string" "$command_base_date")" || normalized_due_status=$?
    case "$normalized_due_status" in
      0) due_string="$normalized_due" ;;
      2) ;;
      *) emit_failed capture-task request_failure ;;
    esac
  fi
  draft_json="$(mutation_draft_task_create "$content" "$due_string")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    emit_failed capture-task request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"
  mutation_extra="$(jq -c . <<<"$mutation_extra")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        json_out "$stored_output"
        return 0
      fi
      emit_failed capture-task request_failure "$mutation_extra"
      ;;
    blocked)
      emit_failed capture-task mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      emit_failed capture-task mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      emit_failed capture-task idempotency_collision "$mutation_extra"
      ;;
    unsafe_replay_state)
      emit_failed capture-task unsafe_replay_state "$mutation_extra"
      ;;
    execute|retry_partial)
      ;;
    *)
      emit_failed capture-task request_failure "$mutation_extra"
      ;;
  esac

  local add_stdout add_stderr task_json task_id operation verified due_applied runtime_json result_json output_json
  add_stdout=$(mktemp)
  add_stderr=$(mktemp)

  if [[ "$decision" == "retry_partial" ]]; then
    task_id="$(jq -r '.idempotency.record.result.partial.external_object_id // empty' <<<"$prepare_json")"
    if [[ -z "$task_id" ]]; then
      emit_failed capture-task unsafe_replay_state "$mutation_extra"
    fi
    task_json="$(jq -nc --arg id "$task_id" --arg content "$content" '{id:$id,content:$content,source:"partial-retry"}')"
  else
    local adapter_status failure_class
    local preflight_json preflight_status preflight_extra
    preflight_json="$(semantic_duplicate_preflight "$content" "$due_string" "$command_base_date")"
    preflight_status="$(jq -r '.status // "unable_to_verify_duplicates"' <<<"$preflight_json")"
    case "$preflight_status" in
      safe_to_create)
        ;;
      duplicate_existing|semantic_duplicate_confirmation_required)
        preflight_extra="$(jq -nc --argjson extra "$mutation_extra" --argjson preflight "$preflight_json" '$extra + {preflight:$preflight}')"
        result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failed_step duplicate-preflight --arg failure_class "$preflight_status" --argjson preflight "$preflight_json" '{runtime_schema:$runtime_schema,failed_step:$failed_step,failure_class:$failure_class,preflight:$preflight}')"
        if ! mutation_record_status "$gateway_plan" failed "$result_json"; then
          cleanup_files "$add_stdout" "$add_stderr"
          emit_failed capture-task state_write_failed "$preflight_extra"
        fi
        cleanup_files "$add_stdout" "$add_stderr"
        emit_capture_task_preflight_failed "$preflight_status" "$mutation_extra" "$preflight_json"
        ;;
      unable_to_verify_duplicates|*)
        preflight_status=unable_to_verify_duplicates
        preflight_extra="$(jq -nc --argjson extra "$mutation_extra" --argjson preflight "$preflight_json" '$extra + {preflight:$preflight}')"
        result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failed_step duplicate-preflight --arg failure_class "$preflight_status" --argjson preflight "$preflight_json" '{runtime_schema:$runtime_schema,failed_step:$failed_step,failure_class:$failure_class,preflight:$preflight}')"
        if ! mutation_record_status "$gateway_plan" failed "$result_json"; then
          cleanup_files "$add_stdout" "$add_stderr"
          emit_failed capture-task state_write_failed "$preflight_extra"
        fi
        cleanup_files "$add_stdout" "$add_stderr"
        emit_capture_task_preflight_failed "$preflight_status" "$mutation_extra" "$preflight_json"
        ;;
    esac
    adapter_status=0
    adapter_run "$add_stdout" "$add_stderr" add-task "$content" || adapter_status=$?
    if [[ "$adapter_status" != 0 ]]; then
      failure_class="$(map_adapter_error_class "$add_stderr" "$adapter_status")"
      runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
      if ! state_write_runtime "$runtime_json"; then
        emit_failed capture-task state_write_failed
      fi
      result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"add-task",failure_class:$failure_class}')"
      if ! mutation_record_status "$gateway_plan" failed "$result_json"; then
        emit_failed capture-task state_write_failed "$mutation_extra"
      fi
      emit_failed capture-task "$failure_class" "$mutation_extra"
    fi

    task_json="$(cat "$add_stdout")"
    task_id="$(jq -r '.id // empty' <<<"$task_json")"
    if [[ -z "$task_id" ]]; then
      result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" '{runtime_schema:$runtime_schema,failed_step:"add-task",failure_class:"verification_failed"}')"
      if ! mutation_record_status "$gateway_plan" failed "$result_json"; then
        emit_failed capture-task state_write_failed "$mutation_extra"
      fi
      emit_failed capture-task verification_failed "$mutation_extra"
    fi
  fi

  operation=add-task
  verified=true
  due_applied=false

  if [[ -n "$due_string" ]]; then
    local due_stdout due_stderr
    due_stdout=$(mktemp)
    due_stderr=$(mktemp)
    adapter_status=0
    adapter_run "$due_stdout" "$due_stderr" update-due "$task_id" "$due_string" || adapter_status=$?
    if [[ "$adapter_status" != 0 ]]; then
      failure_class="$(map_adapter_error_class "$due_stderr" "$adapter_status")"
      runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
      if ! state_write_runtime "$runtime_json"; then
        emit_failed capture-task state_write_failed
      fi
      result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg task_id "$task_id" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,partial:{external_object_id:$task_id,failed_step:"update-due",failure_class:$failure_class}}')"
      if ! mutation_record_status "$gateway_plan" failed "$result_json"; then
        cleanup_files "$due_stdout" "$due_stderr" "$add_stdout" "$add_stderr"
        emit_failed capture-task state_write_failed "$mutation_extra"
      fi
      cleanup_files "$due_stdout" "$due_stderr" "$add_stdout" "$add_stderr"
      emit_failed capture-task "$failure_class" "$mutation_extra"
    fi
    task_json="$(cat "$due_stdout")"
    operation=add-task-and-update-due
    due_applied=true
    cleanup_files "$due_stdout" "$due_stderr"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  if ! state_write_runtime "$runtime_json"; then
    emit_failed capture-task state_write_failed
  fi

  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command capture-task --arg status ok --arg operation "$operation" --argjson verified "$verified" --argjson due_applied "$due_applied" --argjson task "$task_json" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,due_applied:$due_applied,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  if ! mutation_record_status "$gateway_plan" verified "$result_json"; then
    emit_failed capture-task state_write_failed "$mutation_extra"
  fi
  json_out "$output_json"
  cleanup_files "$add_stdout" "$add_stderr"
}

task_completion_command() {
  local command="$1" adapter_command="$2"
  shift 2
  local task_id="" idempotency_hint="" confirmed_by_user=false
  while (($#)); do
    case "$1" in
      --task-id|--task-hint)
        require_option_value "$command" "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --idempotency-hint)
        require_option_value "$command" "${2:-}"
        idempotency_hint="$2"
        shift 2
        ;;
      --confirmed-by-user|--user-confirmed)
        confirmed_by_user=true
        shift
        ;;
      *)
        emit_failed "$command" invalid_argument
        ;;
    esac
  done
  [[ -n "$task_id" ]] || emit_failed "$command" invalid_argument

  local action="${command%-task}"
  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed "$command" state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed "$command" "$failure_class"
  fi
  pre_state="$(cat "$pre_stdout")"

  draft_json="$(mutation_draft_task_completion_change "$task_id" "$action" "$pre_state" "$idempotency_hint" "$confirmed_by_user")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed "$command" request_failure
  fi
  decision="$(jq -r '.decision // "missing"' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"
  case "$decision" in
    execute)
      ;;
    duplicate_verified)
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
      fi
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" request_failure "$mutation_extra"
      ;;
    missing_state|helper_unavailable)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" request_failure "$mutation_extra"
      ;;
    blocked)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" idempotency_collision "$mutation_extra"
      ;;
    unsafe_replay_state|retry_partial)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" unsafe_replay_state "$mutation_extra"
      ;;
    *)
      cleanup_files "$pre_stdout" "$pre_stderr"
      emit_failed "$command" request_failure "$mutation_extra"
      ;;
  esac

  local action_stdout action_stderr adapter_status failure_class runtime_json result_json output_json task_payload stored_output
  action_stdout=$(mktemp)
  action_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$action_stdout" "$action_stderr" "$adapter_command" "$task_id" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$action_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed "$command" state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg task_id "$task_id" --arg failed_step "$command" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,partial:{external_object_id:$task_id,failed_step:$failed_step,failure_class:$failure_class}}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed "$command" state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$action_stdout" "$action_stderr"
    emit_failed "$command" "$failure_class" "$mutation_extra"
  fi

  if [[ -s "$action_stdout" ]]; then
    task_payload="$(cat "$action_stdout")"
  else
    task_payload="$(jq -nc --arg id "$task_id" --arg command "$command" '{id:$id,verified:true,command:$command}')"
  fi
  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed "$command" state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command "$command" --arg status ok --arg operation "$command" --argjson verified true --argjson task "$task_payload" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed "$command" state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$action_stdout" "$action_stderr"
  json_out "$output_json"
}

update_due_command() {
  local task_id="" due_string=""
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value update-due "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --due)
        require_option_value update-due "${2:-}"
        due_string="$2"
        shift 2
        ;;
      *)
        emit_failed update-due invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || -z "$due_string" ]]; then
    emit_failed update-due invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra command_base_date="" normalized_due_status=0 normalized_due=""
  ts="$(now_utc)"
  command_base_date="$(date -u -d "$ts" +%F 2>/dev/null || true)"
  [[ -n "$command_base_date" ]] || emit_failed update-due request_failure
  normalized_due="$(normalize_due_string_if_supported "$due_string" "$command_base_date")" || normalized_due_status=$?
  case "$normalized_due_status" in
    0) due_string="$normalized_due" ;;
    2) emit_failed update-due invalid_argument ;;
    *) emit_failed update-due request_failure ;;
  esac
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-due state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-due "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,project_id,section_id,parent_id,labels,due,priority,updated_at,deadline}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_due_update "$task_id" "$due_string" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-due request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed update-due request_failure "$mutation_extra"
      ;;
    blocked)
      emit_failed update-due mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      emit_failed update-due mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      emit_failed update-due idempotency_collision "$mutation_extra"
      ;;
    retry_partial)
      partial_failure_class="$(jq -r '.idempotency.record.result.partial.failure_class // empty' <<<"$prepare_json")"
      partial_failed_step="$(jq -r '.idempotency.record.result.partial.failed_step // empty' <<<"$prepare_json")"
      case "${partial_failed_step}:${partial_failure_class}" in
        update-due:network_failure|update-due:rate_limited)
          ;;
        *)
          emit_failed update-due unsafe_replay_state "$mutation_extra"
          ;;
      esac
      ;;
    unsafe_replay_state)
      emit_failed update-due unsafe_replay_state "$mutation_extra"
      ;;
    execute)
      ;;
    *)
      emit_failed update-due request_failure "$mutation_extra"
      ;;
  esac

  local due_stdout due_stderr adapter_status failure_class runtime_json result_json output_json
  due_stdout=$(mktemp)
  due_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$due_stdout" "$due_stderr" update-due "$task_id" "$due_string" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$due_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-due state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg task_id "$task_id" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,partial:{external_object_id:$task_id,failed_step:"update-due",failure_class:$failure_class}}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed update-due state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$due_stdout" "$due_stderr"
    emit_failed update-due "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed update-due state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command update-due --arg status ok --arg operation update-due --argjson verified true --arg due_string "$due_string" --argjson task "$(cat "$due_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,due_string:$due_string,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed update-due state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$due_stdout" "$due_stderr"
  json_out "$output_json"
}


update_deadline_command() {
  local task_id="" deadline_date=""
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value update-deadline "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --deadline|--deadline-date)
        require_option_value update-deadline "${2:-}"
        deadline_date="$2"
        shift 2
        ;;
      *)
        emit_failed update-deadline invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || -z "$deadline_date" ]] || ! valid_date_ymd "$deadline_date"; then
    emit_failed update-deadline invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-deadline state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-deadline "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_deadline_update "$task_id" "$deadline_date" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-deadline request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed update-deadline request_failure "$mutation_extra"
      ;;
    blocked)
      emit_failed update-deadline mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      emit_failed update-deadline mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      emit_failed update-deadline idempotency_collision "$mutation_extra"
      ;;
    unsafe_replay_state|retry_partial)
      emit_failed update-deadline unsafe_replay_state "$mutation_extra"
      ;;
    execute)
      ;;
    *)
      emit_failed update-deadline request_failure "$mutation_extra"
      ;;
  esac

  local deadline_stdout deadline_stderr adapter_status failure_class runtime_json result_json output_json
  deadline_stdout=$(mktemp)
  deadline_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$deadline_stdout" "$deadline_stderr" update-deadline-date "$task_id" "$deadline_date" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$deadline_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-deadline state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"update-deadline",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed update-deadline state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$deadline_stdout" "$deadline_stderr"
    emit_failed update-deadline "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed update-deadline state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command update-deadline --arg status ok --arg operation update-deadline --argjson verified true --arg deadline_date "$deadline_date" --argjson task "$(cat "$deadline_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,deadline_date:$deadline_date,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed update-deadline state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$deadline_stdout" "$deadline_stderr"
  json_out "$output_json"
}

clear_deadline_command() {
  local task_id=""
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value clear-deadline "${2:-}"
        task_id="$2"
        shift 2
        ;;
      *)
        emit_failed clear-deadline invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" ]]; then
    emit_failed clear-deadline invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed clear-deadline state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed clear-deadline "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_deadline_clear "$task_id" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed clear-deadline request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed clear-deadline request_failure "$mutation_extra"
      ;;
    blocked)
      emit_failed clear-deadline mutation_blocked "$mutation_extra"
      ;;
    awaiting_confirmation)
      emit_failed clear-deadline mutation_confirmation_required "$mutation_extra"
      ;;
    collision)
      emit_failed clear-deadline idempotency_collision "$mutation_extra"
      ;;
    unsafe_replay_state|retry_partial)
      emit_failed clear-deadline unsafe_replay_state "$mutation_extra"
      ;;
    execute)
      ;;
    *)
      emit_failed clear-deadline request_failure "$mutation_extra"
      ;;
  esac

  local deadline_stdout deadline_stderr adapter_status failure_class runtime_json result_json output_json
  deadline_stdout=$(mktemp)
  deadline_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$deadline_stdout" "$deadline_stderr" clear-deadline "$task_id" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$deadline_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed clear-deadline state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"clear-deadline",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed clear-deadline state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$deadline_stdout" "$deadline_stderr"
    emit_failed clear-deadline "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed clear-deadline state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command clear-deadline --arg status ok --arg operation clear-deadline --argjson verified true --argjson task "$(cat "$deadline_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed clear-deadline state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$deadline_stdout" "$deadline_stderr"
  json_out "$output_json"
}

update_labels_command() {
  local task_id="" labels_csv="" labels_seen=false
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value update-labels "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --labels-csv|--labels)
        if (($# < 2)); then
          emit_failed update-labels invalid_argument
        fi
        labels_csv="${2-}"
        labels_seen=true
        shift 2
        ;;
      *)
        emit_failed update-labels invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || "$labels_seen" != true ]]; then
    emit_failed update-labels invalid_argument
  fi

  local labels_json ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  labels_json="$(jq -nc --arg labels_csv "$labels_csv" '$labels_csv | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(length>0)) | unique | sort')" || emit_failed update-labels invalid_argument
  labels_csv="$(jq -r 'join(",")' <<<"$labels_json")"
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-labels state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-labels "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,description,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_labels_update "$task_id" "$labels_json" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-labels request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed update-labels request_failure "$mutation_extra"
      ;;
    blocked) emit_failed update-labels mutation_blocked "$mutation_extra" ;;
    awaiting_confirmation) emit_failed update-labels mutation_confirmation_required "$mutation_extra" ;;
    collision) emit_failed update-labels idempotency_collision "$mutation_extra" ;;
    unsafe_replay_state|retry_partial) emit_failed update-labels unsafe_replay_state "$mutation_extra" ;;
    execute) ;;
    *) emit_failed update-labels request_failure "$mutation_extra" ;;
  esac

  local labels_stdout labels_stderr adapter_status failure_class runtime_json result_json output_json
  labels_stdout=$(mktemp)
  labels_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$labels_stdout" "$labels_stderr" update-labels "$task_id" "$labels_csv" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$labels_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-labels state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"update-labels",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed update-labels state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$labels_stdout" "$labels_stderr"
    emit_failed update-labels "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed update-labels state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command update-labels --arg status ok --arg operation update-labels --argjson verified true --argjson task "$(cat "$labels_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed update-labels state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$labels_stdout" "$labels_stderr"
  json_out "$output_json"
}

update_content_command() {
  local task_id="" content=""
  while (($#)); do
    case "$1" in
      --task-id|--task-hint)
        require_option_value update-content "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --content)
        require_option_value update-content "${2:-}"
        content="$2"
        shift 2
        ;;
      *)
        emit_failed update-content invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || -z "$content" ]]; then
    emit_failed update-content invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-content state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-content "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,description,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_content_update "$task_id" "$content" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-content request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed update-content request_failure "$mutation_extra"
      ;;
    blocked) emit_failed update-content mutation_blocked "$mutation_extra" ;;
    awaiting_confirmation) emit_failed update-content mutation_confirmation_required "$mutation_extra" ;;
    collision) emit_failed update-content idempotency_collision "$mutation_extra" ;;
    unsafe_replay_state|retry_partial) emit_failed update-content unsafe_replay_state "$mutation_extra" ;;
    execute) ;;
    *) emit_failed update-content request_failure "$mutation_extra" ;;
  esac

  local content_stdout content_stderr adapter_status failure_class runtime_json result_json output_json
  content_stdout=$(mktemp)
  content_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$content_stdout" "$content_stderr" update-task-fields "$task_id" "$content" "" "" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$content_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-content state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"update-content",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed update-content state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$content_stdout" "$content_stderr"
    emit_failed update-content "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed update-content state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command update-content --arg status ok --arg operation update-content --argjson verified true --argjson task "$(cat "$content_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed update-content state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$content_stdout" "$content_stderr"
  json_out "$output_json"
}

update_priority_command() {
  local task_id="" priority=""
  while (($#)); do
    case "$1" in
      --task-id|--task-hint)
        require_option_value update-priority "${2:-}"
        task_id="$2"
        shift 2
        ;;
      --priority)
        require_option_value update-priority "${2:-}"
        priority="$2"
        shift 2
        ;;
      *)
        emit_failed update-priority invalid_argument
        ;;
    esac
  done

  if [[ -z "$task_id" || ! "$priority" =~ ^[1-4]$ ]]; then
    emit_failed update-priority invalid_argument
  fi

  local ts pre_stdout pre_stderr pre_status pre_state draft_json prepare_json decision gateway_plan mutation_extra
  ts="$(now_utc)"
  pre_stdout=$(mktemp)
  pre_stderr=$(mktemp)
  pre_status=0
  adapter_run "$pre_stdout" "$pre_stderr" task "$task_id" || pre_status=$?
  if [[ "$pre_status" != 0 ]]; then
    local failure_class runtime_json
    failure_class="$(map_adapter_error_class "$pre_stderr" "$pre_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-priority state_write_failed
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-priority "$failure_class"
  fi
  pre_state="$(jq -c '{id,content,description,project_id,section_id,parent_id,labels,due,deadline,priority,updated_at}' "$pre_stdout")"

  draft_json="$(mutation_draft_task_priority_update "$task_id" "$priority" "$pre_state")"
  if ! prepare_json="$(mutation_helper_run prepare - <<<"$draft_json")"; then
    cleanup_files "$pre_stdout" "$pre_stderr"
    emit_failed update-priority request_failure
  fi
  decision="$(jq -r '.decision' <<<"$prepare_json")"
  gateway_plan="$(jq -c '.gateway_plan' <<<"$prepare_json")"
  mutation_extra="$(jq -c '{mutation:{gateway_plan:.gateway_plan,idempotency:.idempotency}}' <<<"$prepare_json")"

  case "$decision" in
    duplicate_verified)
      local stored_output
      stored_output="$(jq -c '.idempotency.record.result.output // empty' <<<"$prepare_json")"
      if [[ -n "$stored_output" && "$stored_output" != "null" ]]; then
        cleanup_files "$pre_stdout" "$pre_stderr"
        json_out "$stored_output"
        return 0
      fi
      emit_failed update-priority request_failure "$mutation_extra"
      ;;
    blocked) emit_failed update-priority mutation_blocked "$mutation_extra" ;;
    awaiting_confirmation) emit_failed update-priority mutation_confirmation_required "$mutation_extra" ;;
    collision) emit_failed update-priority idempotency_collision "$mutation_extra" ;;
    unsafe_replay_state|retry_partial) emit_failed update-priority unsafe_replay_state "$mutation_extra" ;;
    execute) ;;
    *) emit_failed update-priority request_failure "$mutation_extra" ;;
  esac

  local priority_stdout priority_stderr adapter_status failure_class runtime_json result_json output_json
  priority_stdout=$(mktemp)
  priority_stderr=$(mktemp)
  adapter_status=0
  adapter_run "$priority_stdout" "$priority_stderr" update-task-fields "$task_id" "" "" "$priority" || adapter_status=$?
  if [[ "$adapter_status" != 0 ]]; then
    failure_class="$(map_adapter_error_class "$priority_stderr" "$adapter_status")"
    runtime_json="$(runtime_with_updates --arg fc "$failure_class" --arg ts "$ts" '.last_failure_class = $fc | .last_failure_at = $ts')"
    state_write_runtime "$runtime_json" || emit_failed update-priority state_write_failed "$mutation_extra"
    result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --arg failure_class "$failure_class" '{runtime_schema:$runtime_schema,failed_step:"update-priority",failure_class:$failure_class}')"
    mutation_record_status "$gateway_plan" failed "$result_json" || emit_failed update-priority state_write_failed "$mutation_extra"
    cleanup_files "$pre_stdout" "$pre_stderr" "$priority_stdout" "$priority_stderr"
    emit_failed update-priority "$failure_class" "$mutation_extra"
  fi

  runtime_json="$(runtime_with_updates --arg ts "$ts" '.last_verified_at = $ts | .last_failure_class = null')"
  state_write_runtime "$runtime_json" || emit_failed update-priority state_write_failed "$mutation_extra"
  output_json="$(jq -nc --arg contract_version "$CONTRACT_VERSION" --arg command update-priority --arg status ok --arg operation update-priority --argjson verified true --argjson task "$(cat "$priority_stdout")" --argjson mutation "$mutation_extra" '{contract_version:$contract_version,command:$command,status:$status,operation:$operation,verified:$verified,task:$task} + $mutation')"
  result_json="$(jq -nc --arg runtime_schema "$CONTRACT_VERSION" --argjson output "$output_json" '{runtime_schema:$runtime_schema,verified:true,output:$output}')"
  mutation_record_status "$gateway_plan" verified "$result_json" || emit_failed update-priority state_write_failed "$mutation_extra"
  cleanup_files "$pre_stdout" "$pre_stderr" "$priority_stdout" "$priority_stderr"
  json_out "$output_json"
}

update_description_command() {
  local task_id="" description="" description_seen=false
  while (($#)); do
    case "$1" in
      --task-id)
        require_option_value update-description "${2:-}"
        task_id="$2"
        shift 2
        ;;
