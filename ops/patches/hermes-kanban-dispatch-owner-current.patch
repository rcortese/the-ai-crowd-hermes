     return out, warnings
 
 
+def dispatch_refusal_payload(
+    board_meta: dict,
+    *,
+    dispatch_owner: Optional[str] = None,
+    dispatch_unowned_boards: object = True,
+    dry_run: bool = False,
+) -> Optional[dict]:
+    """Return a structured dispatch no-op payload for a non-dispatchable board.
+
+    Manual/API dispatch entrypoints call this before ``dispatch_once`` so a
+    board skipped by owner routing is reported as a successful no-op instead
+    of accidentally claiming work. ``None`` means the board is dispatchable.
+    """
+    info = board_dispatchability(
+        board_meta,
+        dispatch_owner=dispatch_owner,
+        dispatch_unowned_boards=dispatch_unowned_boards,
+    )
+    if info.get("dispatchable"):
+        return None
+    return {
+        "reclaimed": 0,
+        "crashed": [],
+        "timed_out": [],
+        "auto_blocked": [],
+        "promoted": 0,
+        "spawned": [],
+        "skipped_unassigned": [],
+        "skipped_nonspawnable": [],
+        "dispatchable": False,
+        "dispatch_owner": info.get("dispatch_owner"),
+        "dispatchability_warning": info.get("dispatchability_warning"),
+        "skipped_dispatch": True,
+        "dry_run": bool(dry_run),
+    }
+
