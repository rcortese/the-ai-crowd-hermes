+  }};
+}}
+for (const id of ['agentHealthBanner', 'agentHealthTitle', 'agentHealthDetails', 'btnRestartGateway']) makeNode(id);
+function $(id) {{ return nodes[id] || null; }}
+const localStorage = {{getItem: () => null, setItem: () => {{}}, removeItem: () => {{}}}};
+const document = {{visibilityState: 'visible'}};
+let _agentHealthLastState = 'unknown';
+let _lastGatewayRestartTime = 0;
+function _agentHealthDismissed() {{ return false; }}
+function _setAgentHealthDismissed(_value) {{}}
+{functions}
+
+async function classify(payload) {{
+  api = async () => payload;
+  await pollAgentHealth();
+  return {{
+    state: _agentHealthLastState,
+    bannerHidden: nodes.agentHealthBanner.hidden,
+    bannerVisible: nodes.agentHealthBanner.classList.contains('visible'),
+    title: nodes.agentHealthTitle.textContent,
