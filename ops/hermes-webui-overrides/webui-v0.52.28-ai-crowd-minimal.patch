+    restartHidden: nodes.btnRestartGateway.hidden,
+    restartDisabled: nodes.btnRestartGateway.disabled,
+  }};
+}}
+
+(async () => {{
+  const detailed = await classify({{alive: true, details: {{telemetry_state: 'detailed', gateway_state: 'running'}}}});
+  const degraded = await classify({{alive: true, details: {{degraded: true, telemetry_state: 'basic_fallback'}}}});
+  const down = await classify({{alive: false, details: {{state: 'down'}}}});
+  console.log(JSON.stringify({{detailed, degraded, down}}));
+}})().catch(error => {{ console.error(error); process.exit(1); }});
+"""
+    result = subprocess.run(
+        ["node", "-e", harness],
+        check=True,
+        capture_output=True,
+        text=True,
+    )
+    states = json.loads(result.stdout)
+
+    assert states["detailed"]["bannerHidden"] is True
+    assert states["detailed"]["bannerVisible"] is False
+    assert states["degraded"]["state"] == "degraded"
