index 00000000..a6a34139
--- /dev/null
+++ b/api/service_session_launch.py
@@ -0,0 +1,187 @@
+"""Narrow service capability for creating a persistent WebUI session and turn.
+
+This is intentionally not a general HTTP proxy and is distinct from browser
+cookie authentication.  The capability is disabled unless its service secret is
+provided by the runtime environment.
+"""
+from __future__ import annotations
+
+import hmac
+import logging
+import os
+import re
+from contextlib import contextmanager
+
+from api.helpers import j
+
+logger = logging.getLogger(__name__)
+
+PATH = "/api/internal/session-launch"
+HEADER = "X-Hermes-Service-Token"
+TOKEN_ENV = "HERMES_WEBUI_SESSION_LAUNCH_TOKEN"
+_MAX_PROMPT_CHARS = 24_000
+_MAX_MODEL_CHARS = 256
+_PROFILE_RE = re.compile(r"^[a-z0-9][a-z0-9_-]{0,63}$")
+_ALLOWED_FIELDS = frozenset({"profile", "workspace", "model", "reasoning", "initial_prompt"})
+
+
+def is_service_launch_path(path: str) -> bool:
+    return path == PATH
+
+
+def _configured_token() -> str:
+    return os.environ.get(TOKEN_ENV, "").strip()
+
+
+def _authorized(handler) -> bool:
+    expected = _configured_token()
+    presented = str(handler.headers.get(HEADER, "") or "")
+    # An absent/short secret is a configuration error, never a permissive mode.
+    return len(expected) >= 32 and hmac.compare_digest(expected, presented)
+
+
+def _error(handler, message: str, status: int):
+    return j(handler, {"error": message}, status=status)
+
+
+def _validate_body(body: object) -> tuple[dict | None, str | None]:
+    if not isinstance(body, dict):
+        return None, "JSON object required"
+    unknown = set(body) - _ALLOWED_FIELDS
+    if unknown:
+        return None, "unsupported field"
+
+    profile = str(body.get("profile") or "").strip()
+    workspace = str(body.get("workspace") or "").strip()
+    prompt = str(body.get("initial_prompt") or "").strip()
+    model = body.get("model")
+    reasoning = body.get("reasoning")
+    if not profile or not _PROFILE_RE.fullmatch(profile):
+        return None, "valid profile is required"
+    if not workspace:
+        return None, "workspace is required"
+    if not prompt or len(prompt) > _MAX_PROMPT_CHARS:
+        return None, "initial_prompt is required and must not exceed 24000 characters"
+    if model is not None and (not isinstance(model, str) or not model.strip() or len(model.strip()) > _MAX_MODEL_CHARS):
+        return None, "model must be a non-empty string of at most 256 characters"
+    # Hermes currently resolves reasoning from the selected profile/model config.
+    # Accept only the explicit value which accurately represents that behavior.
+    if reasoning not in (None, "", "profile_default"):
+        return None, "reasoning must be profile_default"
+    return {
+        "profile": profile,
+        "workspace": workspace,
+        "model": model.strip() if isinstance(model, str) else None,
+        "initial_prompt": prompt,
+    }, None
+
+
+def _profile_exists(profile: str) -> bool:
+    from api.profiles import list_profiles_api
+    return any(str(row.get("name") or "") == profile for row in list_profiles_api())
+
+
+def _verify_active_stream(session_id: str, stream_id: str) -> bool:
+    """Prove this launch's stream is the session's currently active stream.
+
+    This deliberately does not report a global stream count: a caller needs an
+    identity-bound receipt for the session it just launched.
+    """
+    from api.models import STREAMS, STREAMS_LOCK, get_session
+
+    try:
+        session = get_session(session_id)
+    except KeyError:
+        return False
+    if not hmac.compare_digest(str(getattr(session, "active_stream_id", "") or ""), stream_id):
+        return False
+    with STREAMS_LOCK:
+        return stream_id in STREAMS
+
+
+@contextmanager
+def _request_profile(profile: str):
+    from api.profiles import clear_request_profile, set_request_profile
+    set_request_profile(profile)
+    try:
+        yield
+    finally:
+        clear_request_profile()
+
+
+def service_launch_authorized(handler) -> bool:
+    """Authorize the service capability before any request-body parsing."""
+    return _authorized(handler)
+
+
+def handle_service_session_launch(handler, body: object) -> bool:
+    """Create, persist, and start a service-authorized WebUI conversation.
+
+    Responses and logs deliberately exclude the initial prompt and service token.
+    """
+    if not service_launch_authorized(handler):
+        _error(handler, "service authorization required", 401)
+        return True
+    data, error = _validate_body(body)
+    if error:
+        _error(handler, error, 400)
+        return True
+    assert data is not None
+    if not _profile_exists(data["profile"]):
+        _error(handler, "profile not found", 404)
+        return True
+
+    try:
+        from api.models import new_session
+        from api.routes import _session_model_state_from_request, resolve_trusted_workspace, start_session_turn
+
+        with _request_profile(data["profile"]):
+            workspace = str(resolve_trusted_workspace(data["workspace"]))
+            model, provider = _session_model_state_from_request(data["model"], None)
+            session = new_session(
+                workspace=workspace,
+                model=model,
+                model_provider=provider,
+                profile=data["profile"],
+            )
+            # Persist before start: a worker or process failure must not leave a
+            # launched session that vanishes from the WebUI sidebar.
+            session.save()
+            result = start_session_turn(
+                session.session_id,
+                data["initial_prompt"],
+                source="service_session_launch",
+            )
+        status = int(result.get("_status", 200) or 200)
+        if status >= 400:
+            _error(handler, str(result.get("error") or "session launch failed"), status)
+            return True
+        stream_id = str(result.get("stream_id") or "")
+        if not stream_id:
+            _error(handler, "session launch did not create a stream", 502)
+            return True
+        if not _verify_active_stream(session.session_id, stream_id):
+            _error(handler, "session launch stream could not be verified active", 502)
+            return True
+        j(handler, {
+            "session_id": session.session_id,
+            "stream_id": stream_id,
+            "verified_state": {
+                "session_id": session.session_id,
+                "stream_id": stream_id,
+                "active": True,
+            },
+            "profile": data["profile"],
+            "workspace": workspace,
+            "model": model,
+            "reasoning": "profile_default",
+        }, status=201)
+        return True
+    except ValueError as exc:
+        _error(handler, str(exc), 400)
+        return True
+    except Exception:
+        # No request body/token/prompt in diagnostics.
+        logger.exception("service session launch failed")
+        _error(handler, "session launch failed", 500)
+        return True
