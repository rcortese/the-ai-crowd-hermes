diff --git a/tests/test_service_session_launch.py b/tests/test_service_session_launch.py
new file mode 100644
index 0000000000000000000000000000000000000000..8eeee5ecfffc2bff0c5c687055724ff167f6289c
--- /dev/null
+++ b/tests/test_service_session_launch.py
@@ -0,0 +1,76 @@
+"""Regression coverage for the narrow internal persistent-session launcher."""
+from __future__ import annotations
+
+import importlib
+from types import SimpleNamespace
+
+
+def _module(monkeypatch):
+    monkeypatch.setenv("HERMES_WEBUI_SESSION_LAUNCH_TOKEN", "t" * 32)
+    import api.service_session_launch as launch
+    return importlib.reload(launch)
+
+
+def test_service_token_is_fail_closed_and_constant_shape(monkeypatch):
+    launch = _module(monkeypatch)
+    assert launch._authorized(SimpleNamespace(headers={launch.HEADER: "t" * 32}))
+    assert not launch._authorized(SimpleNamespace(headers={launch.HEADER: "wrong"}))
+
+    monkeypatch.delenv("HERMES_WEBUI_SESSION_LAUNCH_TOKEN", raising=False)
+    launch = importlib.reload(launch)
+    assert not launch._authorized(SimpleNamespace(headers={launch.HEADER: "t" * 32}))
+
+
+def test_body_contract_rejects_generic_http_surface(monkeypatch):
+    launch = _module(monkeypatch)
+    valid, error = launch._validate_body({
+        "profile": "moss",
+        "workspace": "/agents/moss/private",
+        "model": "openai/gpt-5.5",
+        "reasoning": "profile_default",
+        "initial_prompt": "hello",
+    })
+    assert error is None
+    assert valid["profile"] == "moss"
+    assert "headers" not in valid
+
+    valid, error = launch._validate_body({
+        "profile": "moss",
+        "workspace": "/agents/moss/private",
+        "initial_prompt": "hello",
+        "url": "https://not-an-api-proxy.invalid",
+    })
+    assert valid is None
+    assert error == "unsupported field"
+
+
+def test_reasoning_is_honest_about_current_profile_default(monkeypatch):
+    launch = _module(monkeypatch)
+    valid, error = launch._validate_body({
+        "profile": "moss",
+        "workspace": "/agents/moss/private",
+        "reasoning": "high",
+        "initial_prompt": "hello",
+    })
+    assert valid is None
+    assert error == "reasoning must be profile_default"
+
+
+def test_active_receipt_is_bound_to_requested_session_and_stream(monkeypatch):
+    launch = _module(monkeypatch)
+    import api.models as models
+
+    session = SimpleNamespace(active_stream_id="stream-1")
+    monkeypatch.setattr(models, "get_session", lambda sid: session if sid == "session-1" else (_ for _ in ()).throw(KeyError(sid)))
+    monkeypatch.setattr(models, "STREAMS", {"stream-1": object()})
+    assert launch._verify_active_stream("session-1", "stream-1")
+    assert not launch._verify_active_stream("session-1", "other-stream")
+    assert not launch._verify_active_stream("other-session", "stream-1")
+
+
+def test_only_the_internal_path_bypasses_browser_auth():
+    from api.service_session_launch import is_service_launch_path
+
+    assert is_service_launch_path("/api/internal/session-launch")
+    assert not is_service_launch_path("/api/session/new")
+    assert not is_service_launch_path("/api/chat/start")
