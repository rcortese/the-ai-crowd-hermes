+def resolve_chat_execution_target(name: str, config_data=None, environ: dict[str, str] | None = None) -> dict:
+    """Choose a chat worker without allowing a configured persona proxy to fall local."""
+    proxy = profile_proxy_for(name, config_data, environ)
+    if proxy is not None:
+        return {
+            "ok": True,
+            "execution_target": "remote_gateway",
+            "gateway_config": dict(proxy),
+        }
+    if webui_gateway_chat_enabled(config_data, environ):
+        return {"ok": True, "execution_target": "local_gateway", "gateway_config": None}
+    return {"ok": True, "execution_target": "local_legacy", "gateway_config": None}
