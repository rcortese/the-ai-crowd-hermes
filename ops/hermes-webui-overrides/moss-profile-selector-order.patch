diff --git a/api/profiles.py b/api/profiles.py
index 0db9ec79..f615933d 100644
--- a/api/profiles.py
+++ b/api/profiles.py
@@ -1886,11 +1886,21 @@ def _with_remote_profile_proxies(rows: list[dict]) -> list[dict]:
         proxies = profile_proxy_public_entries(get_config())
     except Exception:
         proxies = []
-    # Remote profile proxies are cross-persona chat targets. Keep them at the
-    # top of the WebUI profile selector ("personas first"), then show local
-    # Moss profiles after them. profile_proxy_public_entries() already orders
-    # personas within the proxy group.
-    merged = [*proxies, *rows]
+    # Persona proxies are the canonical WebUI targets. Suppress same-named
+    # legacy local profiles so a selector key cannot resolve ambiguously.
+    proxy_names = {str(p.get('name') or '') for p in proxies}
+    moss = [p for p in rows if p.get('name') == 'moss']
+    default = [p for p in rows if p.get('name') == 'default']
+    local_modes = [
+        p for p in rows
+        if p.get('name') not in proxy_names | {'moss', 'default'}
+    ]
+    merged = [
+        *moss,
+        *sorted(proxies, key=lambda p: str(p.get('name') or '').casefold()),
+        *default,
+        *sorted(local_modes, key=lambda p: str(p.get('name') or '').casefold()),
+    ]
     return [{**p, 'is_active': p.get('name') == active} for p in merged]


