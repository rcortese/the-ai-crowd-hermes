ARG HERMES_AGENT_IMAGE=nousresearch/hermes-agent@sha256:adc1fd5b6283c20ad353bfc7b37e63cfdff2e55ce00c865c019e7bf3dbf6e00a
FROM ${HERMES_AGENT_IMAGE}

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        jq \
        poppler-utils \
        python3 \
        python3-venv \
        ripgrep \
        sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# Remove bundled plugins/integration adapters that The AI Crowd does not configure.
# Keep production persona images aligned with the enabled runtime surface.
RUN rm -rf \
        /opt/hermes/plugins/platforms/google_chat \
        /opt/hermes/plugins/platforms/irc \
        /opt/hermes/plugins/platforms/line \
        /opt/hermes/plugins/platforms/simplex \
        /opt/hermes/plugins/platforms/teams \
        /opt/hermes/plugins/google_meet \
        /opt/hermes/plugins/spotify \
        /opt/hermes/plugins/teams_pipeline \
        /opt/hermes/plugins/observability/langfuse \
        /opt/hermes/plugins/memory/byterover \
        /opt/hermes/plugins/memory/hindsight \
        /opt/hermes/plugins/memory/holographic \
        /opt/hermes/plugins/memory/mem0 \
        /opt/hermes/plugins/memory/openviking \
        /opt/hermes/plugins/memory/retaindb \
        /opt/hermes/plugins/memory/supermemory \
        /opt/hermes/plugins/image_gen/openai \
        /opt/hermes/plugins/image_gen/xai \
        /opt/hermes/plugins/video_gen/fal \
        /opt/hermes/plugins/video_gen/xai

LABEL the-ai-crowd.agent="richmond" \
      the-ai-crowd.role="archiveops-stewardship" \
      the-ai-crowd.runtime="hermes-agent-archiveops-constrained"

# Bake Hermes runtime identity as UID/GID 99:100 so Compose can run
# the whole container without a root privilege-drop phase.
RUN usermod -u 99 -g 100 hermes \
    && chown -R 99:100 /opt/hermes/.venv /opt/hermes/ui-tui /opt/hermes/skills /opt/hermes/docker 2>/dev/null || true

ENV PATH="/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}"

# Runtime processes run as UID/GID 99:100 and cannot mutate the root-owned
# Hermes venv. Bake Richmond's enabled Honcho memory client so rebuilds do not
# regress to built-in-only memory.
RUN VIRTUAL_ENV=/opt/hermes/.venv uv pip install honcho-ai==2.0.1 \
    && chmod -R a+rX /opt/hermes/.venv/lib/python3.13/site-packages/honcho*


WORKDIR /agents/richmond/private

USER 99:100

# The AI Crowd image owns Richmond's long-lived Hermes dashboard command.
ENV HERMES_DASHBOARD_TUI=1
CMD ["dashboard", "--host", "0.0.0.0", "--port", "9120", "--insecure", "--no-open", "--tui", "--skip-build"]
