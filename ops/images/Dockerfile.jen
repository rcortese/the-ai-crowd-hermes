ARG HERMES_AGENT_IMAGE=nousresearch/hermes-agent@sha256:adc1fd5b6283c20ad353bfc7b37e63cfdff2e55ce00c865c019e7bf3dbf6e00a
FROM ${HERMES_AGENT_IMAGE}

ARG GOG_VERSION=v0.19.0

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates curl dnsutils fd-find git iputils-ping jq netcat-openbsd \
        openssh-client python3 python3-venv ripgrep rsync sqlite3 tar xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) gog_arch="amd64" ;; \
      arm64) gog_arch="arm64" ;; \
      *) echo "unsupported architecture for gogcli: $arch" >&2; exit 1 ;; \
    esac; \
    version_no_v="${GOG_VERSION#v}"; \
    tmpdir="$(mktemp -d)"; \
    curl -fsSL "https://github.com/openclaw/gogcli/releases/download/${GOG_VERSION}/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" -o "$tmpdir/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz"; \
    curl -fsSL "https://github.com/openclaw/gogcli/releases/download/${GOG_VERSION}/checksums.txt" -o "$tmpdir/checksums.txt"; \
    (cd "$tmpdir" && grep "gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" checksums.txt | sha256sum -c -); \
    tar -xzf "$tmpdir/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" -C "$tmpdir" gog; \
    install -m 0755 "$tmpdir/gog" /usr/local/bin/gog; \
    rm -rf "$tmpdir"; \
    gog --version

# Remove bundled plugins/integration adapters that The AI Crowd does not configure.
# Keep production persona images aligned with the enabled runtime surface.
RUN rm -rf \
        /opt/hermes/plugins/platforms/google_chat \
        /opt/hermes/plugins/platforms/irc \
        /opt/hermes/plugins/platforms/line \
        /opt/hermes/plugins/platforms/simplex \
        /opt/hermes/plugins/platforms/teams \
        /opt/hermes/plugins/google_meet \
        /opt/hermes/plugins/spotify \
        /opt/hermes/plugins/teams_pipeline \
        /opt/hermes/plugins/observability/langfuse \
        /opt/hermes/plugins/memory/byterover \
        /opt/hermes/plugins/memory/hindsight \
        /opt/hermes/plugins/memory/holographic \
        /opt/hermes/plugins/memory/mem0 \
        /opt/hermes/plugins/memory/openviking \
        /opt/hermes/plugins/memory/retaindb \
        /opt/hermes/plugins/memory/supermemory \
        /opt/hermes/plugins/image_gen/openai \
        /opt/hermes/plugins/image_gen/xai \
        /opt/hermes/plugins/video_gen/fal \
        /opt/hermes/plugins/video_gen/xai

LABEL the-ai-crowd.agent="jen" \
      the-ai-crowd.role="productivity-operations" \
      the-ai-crowd.runtime="hermes-agent-productivity"

ENV PATH="/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}"

# Bake Hermes runtime identity as UID/GID 99:100 so Compose can run
# the whole container without a root privilege-drop phase.
RUN usermod -u 99 -g 100 hermes \
    && chown -R 99:100 /opt/hermes/.venv /opt/hermes/ui-tui /opt/hermes/skills /opt/hermes/docker 2>/dev/null || true

# Install and expose Honcho client support in this persona image. Do not rely on
# the upstream base image to include honcho-ai: memory status can show the plugin
# as available while honcho status fails without this package.
RUN VIRTUAL_ENV=/opt/hermes/.venv uv pip install honcho-ai==2.0.1 \
    && chmod -R a+rX /opt/hermes/.venv/lib/python3.13/site-packages/honcho*
ENV GOG_HOME="/opt/data/gog" \
    GOG_KEYRING_BACKEND="file"


WORKDIR /agents/jen/private

USER 99:100

# The AI Crowd image owns the Hermes process topology for Jen:
# gateway in the foreground, dashboard as the entrypoint-managed side process.
ENV HERMES_DASHBOARD=1 \
    HERMES_DASHBOARD_HOST=0.0.0.0 \
    HERMES_DASHBOARD_PORT=9121 \
    HERMES_DASHBOARD_INSECURE=true \
    HERMES_DASHBOARD_TUI=1
CMD ["gateway", "run"]
