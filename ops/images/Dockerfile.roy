ARG HERMES_AGENT_IMAGE=the-ai-crowd/hermes-agent:release-v2026.7.1-fork-d46119a7b448
FROM ${HERMES_AGENT_IMAGE}

USER root

# Source-backed fleet guard: patch the shared Hermes base before validating it.
COPY ops/hermes-agent-overrides/write-safe-root-invalid-config-fail-closed.patch /tmp/write-safe-root.patch
COPY ops/images/write-safe-root-contract.py /opt/hermes/write-safe-root-contract.py
RUN apt-get update \
    && apt-get install -y --no-install-recommends patch \
    && rm -rf /var/lib/apt/lists/*

RUN command -v patch >/dev/null \
    && cd /opt/hermes \
    && patch -p1 < /tmp/write-safe-root.patch \
    && /opt/hermes/.venv/bin/python3 -m py_compile agent/file_safety.py tools/file_operations.py agent/copilot_acp_client.py \
    && /opt/hermes/.venv/bin/python3 /opt/hermes/write-safe-root-contract.py \
    && rm -f /tmp/write-safe-root.patch /opt/hermes/write-safe-root-contract.py

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        dnsutils \
        fd-find \
        git \
        iputils-ping \
        jq \
        netcat-openbsd \
        openssh-client \
        poppler-utils \
        python3 \
        python3-venv \
        ripgrep \
        rsync \
        sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# Remove bundled plugins/integration adapters that The AI Crowd does not configure.
# Keep production persona images aligned with the enabled runtime surface.
RUN rm -rf \
        /opt/hermes/plugins/platforms/google_chat \
        /opt/hermes/plugins/platforms/irc \
        /opt/hermes/plugins/platforms/line \
        /opt/hermes/plugins/platforms/simplex \
        /opt/hermes/plugins/platforms/teams \
        /opt/hermes/plugins/google_meet \
        /opt/hermes/plugins/spotify \
        /opt/hermes/plugins/teams_pipeline \
        /opt/hermes/plugins/observability/langfuse \
        /opt/hermes/plugins/memory/byterover \
        /opt/hermes/plugins/memory/hindsight \
        /opt/hermes/plugins/memory/holographic \
        /opt/hermes/plugins/memory/mem0 \
        /opt/hermes/plugins/memory/openviking \
        /opt/hermes/plugins/memory/retaindb \
        /opt/hermes/plugins/memory/supermemory \
        /opt/hermes/plugins/image_gen/openai \
        /opt/hermes/plugins/image_gen/xai \
        /opt/hermes/plugins/video_gen/fal \
        /opt/hermes/plugins/video_gen/xai

LABEL the-ai-crowd.agent="roy" \
      the-ai-crowd.role="intake-live-input-triage" \
      the-ai-crowd.runtime="hermes-agent-intake-triage"

ENV PATH="/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}"

# Bake Hermes runtime identity as UID/GID 99:100 so Compose can run
# the whole container without a root privilege-drop phase.
RUN usermod -u 99 -g 100 hermes \
    && chown -R 99:100 /opt/hermes/.venv /opt/hermes/ui-tui /opt/hermes/skills /opt/hermes/docker 2>/dev/null || true


# Runtime processes run as UID/GID 99:100 and cannot mutate the root-owned
# Hermes venv. Bake Roy's enabled Honcho memory client so rebuilds do not
# regress to the prior runtime-only hotfix state.
RUN VIRTUAL_ENV=/opt/hermes/.venv uv pip install honcho-ai==2.0.1

ARG GOG_VERSION=v0.30.0
RUN set -eux;     arch="$(uname -m)";     case "$arch" in       x86_64) gog_arch="amd64" ;;       aarch64|arm64) gog_arch="arm64" ;;       *) echo "unsupported architecture for gogcli: $arch" >&2; exit 1 ;;     esac;     version_no_v="${GOG_VERSION#v}";     tmpdir="$(mktemp -d)";     curl -fsSL "https://github.com/openclaw/gogcli/releases/download/${GOG_VERSION}/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" -o "$tmpdir/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz";     curl -fsSL "https://github.com/openclaw/gogcli/releases/download/${GOG_VERSION}/checksums.txt" -o "$tmpdir/checksums.txt";     (cd "$tmpdir" && grep "gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" checksums.txt | sha256sum -c -);     tar -xzf "$tmpdir/gogcli_${version_no_v}_linux_${gog_arch}.tar.gz" -C "$tmpdir" gog;     install -m 0755 "$tmpdir/gog" /usr/local/bin/gog;     rm -rf "$tmpdir";     gog --version


WORKDIR /agents/roy/private

USER 99:100

# The AI Crowd image owns Roy's long-lived Hermes dashboard command.
ENV HERMES_DASHBOARD_TUI=1
CMD ["dashboard", "--host", "0.0.0.0", "--port", "9123", "--insecure", "--no-open", "--tui", "--skip-build"]
