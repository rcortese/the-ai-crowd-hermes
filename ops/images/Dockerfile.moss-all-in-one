'''
new = '''                    for mid in _read_visible_codex_cache_model_ids():
                        if mid not in codex_ids:
                            codex_ids.append(mid)

                    # MOSS PATCH: keep the production picker intentionally small.
                    # The operator requested one model per OpenAI category and no
                    # accidental extra choices after incident recovery.
