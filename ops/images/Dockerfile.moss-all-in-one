FROM the-ai-crowd/moss:local

USER root

ARG HERMES_AGENT_REPO=https://github.com/rcortese/hermes-agent.git
ARG HERMES_AGENT_REV=54fa84fa6925cd5e6d2f5874dff08151ee6e5aec
ARG HERMES_WEBUI_REPO=https://github.com/rcortese/hermes-webui.git
ARG HERMES_WEBUI_REV=2b234e3a4bbe2b680c008d2791f857d4cf96409e

RUN test "$(id -u hermes)" = "99" \
    && test "$(id -g hermes)" = "100"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        supervisor \
    && rm -rf /var/lib/apt/lists/*

RUN mv /opt/hermes/.venv /tmp/hermes-venv \
    && rm -rf /opt/hermes \
    && git clone "${HERMES_AGENT_REPO}" /opt/hermes \
    && cd /opt/hermes \
    && git checkout --detach "${HERMES_AGENT_REV}" \
    && test "$(git rev-parse HEAD)" = "${HERMES_AGENT_REV}" \
    && mv /tmp/hermes-venv /opt/hermes/.venv \
    && /opt/hermes/.venv/bin/python3 -m py_compile \
        hermes_cli/config.py \
        hermes_cli/kanban_db.py \
        hermes_cli/kanban.py \
        gateway/run.py \
        plugins/kanban/dashboard/plugin_api.py \
        tests/hermes_cli/test_kanban_boards.py \
    && /opt/hermes/.venv/bin/python3 -m pytest -o addopts= -q \
        tests/hermes_cli/test_kanban_boards.py \
        tests/plugins/test_kanban_dashboard_plugin.py

RUN git clone "${HERMES_WEBUI_REPO}" /opt/hermes-webui \
    && cd /opt/hermes-webui \
    && git checkout --detach "${HERMES_WEBUI_REV}" \
    && test "$(git rev-parse HEAD)" = "${HERMES_WEBUI_REV}" \
    && /opt/hermes/.venv/bin/python3 -m py_compile api/kanban_bridge.py \
    && /opt/hermes/.venv/bin/python3 -m pytest -o addopts= -q tests/test_kanban_bridge.py tests/test_kanban_bridge_dispatch_owner.py tests/test_kanban_owner_patch_semantics.py tests/test_kanban_owner_ui_behavior.py \
    && WEBUI_VERSION="$(git describe --tags --always --dirty)" \
    && printf "__version__ = '%s'\\n" "$WEBUI_VERSION" > /opt/hermes-webui/api/_version.py \
    && uv pip install --python /opt/hermes/.venv/bin/python3 --no-cache-dir -r /opt/hermes-webui/requirements.txt \
    && uv pip install --python /opt/hermes/.venv/bin/python3 --no-cache-dir -e /opt/hermes \
    && rm -rf /opt/hermes-webui/.git \
    && chown -R 99:100 /opt/hermes-webui



