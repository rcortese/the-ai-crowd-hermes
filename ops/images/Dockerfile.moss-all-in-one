                        # MOSS PATCH: expose only a confirmed zero-cost Nous fallback
                        # and suppress Anthropic/paid catalog drift in the picker.
                        live_ids = [mid for mid in ["openrouter/owl-alpha"] if mid in live_ids]
                        # Sticky-selection signal: prefer the explicitly-active
                        # model from cfg["model"]["model"] (what the user is
                        # currently using) over cfg["model"]["default"] (the
                        # configured default suggestion). Falls back to the
                        # latter so first-load before any selection still works.
'''
if new not in text:
    if old not in text:
        raise SystemExit(f'nous patch anchor not found in {config}')
    text = text.replace(old, new, 1)
config.write_text(text)
py_compile.compile(str(config), doraise=True)

providers = Path('/opt/hermes-webui/api/providers.py')
text = providers.read_text()
old = '''    for pid in sorted(known_ids):
        display_name = _PROVIDER_DISPLAY.get(pid, pid.replace("-", " ").title())
