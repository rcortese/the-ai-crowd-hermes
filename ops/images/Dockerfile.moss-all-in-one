# - Model surfaces are intentionally constrained to the operator-approved list:
#   OpenAI Codex: gpt-5.5, gpt-5.4-mini, gpt-5.3-codex-spark;
#   Nous Portal: openrouter/owl-alpha only; no Anthropic/Claude entries.
RUN /opt/hermes/.venv/bin/python3 - <<'PY'
