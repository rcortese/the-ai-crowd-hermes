# Build guard: the all-in-one image must use one Python runtime only.
RUN test ! -e /opt/hermes-webui/venv \
    && HERMES_WEBUI_AGENT_DIR=/opt/hermes \
       HERMES_WEBUI_STATE_DIR=/tmp/hermes-webui-build-check \
       HERMES_WEBUI_DEFAULT_WORKSPACE=/agents/moss/private \
       /opt/hermes/.venv/bin/python3 - <<'PY'
from pathlib import Path
import importlib
import sys

if not sys.executable.startswith('/opt/hermes/.venv/'):
    raise SystemExit(f'wrong Python executable for WebUI import: {sys.executable}')
if Path('/opt/hermes-webui/venv').exists():
    raise SystemExit('/opt/hermes-webui/venv must not exist in all-in-one image')

sys.path.insert(0, '/opt/hermes-webui')
for module_name in ('server', 'api.config', 'api.providers'):
    importlib.import_module(module_name)
PY

# Runtime UID 99 performs WebUI update checks against /opt/hermes.
# Keep the baked agent checkout both Git-safe and writable after root-run build patches.
RUN git config --system --add safe.directory /opt/hermes \
    && chown -R 99:100 /opt/hermes

COPY ops/supervisor/moss-all-in-one-supervisord.conf /etc/supervisor/conf.d/moss-all-in-one.conf

ENV PATH="/opt/hermes/.venv/bin:/opt/data/.local/bin:${PATH}" \
    HOME=/opt/data \
    HERMES_HOME=/opt/data \
    HERMES_WEBUI_AGENT_DIR=/opt/hermes \
    HERMES_WEBUI_HOST=0.0.0.0 \
    HERMES_WEBUI_PORT=8787 \
    HERMES_WEBUI_STATE_DIR=/opt/data/webui \
    HERMES_WEBUI_DEFAULT_WORKSPACE=/agents/moss/private \
    HERMES_DASHBOARD=1 \
    HERMES_DASHBOARD_HOST=0.0.0.0 \
    HERMES_DASHBOARD_PORT=9119 \
    HERMES_DASHBOARD_TUI=1

WORKDIR /agents/moss/private

ENTRYPOINT ["/usr/bin/tini", "-g", "--"]
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/moss-all-in-one.conf", "-n"]
