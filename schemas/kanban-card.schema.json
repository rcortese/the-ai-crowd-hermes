{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/the-ai-crowd-hermes/schemas/kanban-card.schema.json",
  "title": "Hermes Kanban Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "owner", "decision_owner", "status", "created_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,80}$" },
    "type": {
      "type": "string",
      "enum": ["migration-task", "ops-task", "handoff", "review-gate", "incident", "decision-record", "automation-run", "blocker"]
    },
    "title": { "type": "string", "minLength": 3, "maxLength": 160 },
    "owner": { "type": "string", "enum": ["moss", "jen", "denholm", "richmond", "roy", "the-elders", "operator"] },
    "decision_owner": { "type": "string", "enum": ["moss", "jen", "denholm", "richmond", "roy", "the-elders", "operator"] },
    "executor": { "type": "string", "enum": ["moss", "jen", "denholm", "richmond", "roy", "the-elders", "operator"] },
    "status": {
      "type": "string",
      "enum": ["inbox", "triaged", "owned", "in_progress", "under_review", "changes_required", "blocked", "waiting_user", "approved", "done", "archived"]
    },
    "scope": { "type": "string", "maxLength": 2000 },
    "source_refs": { "type": "array", "items": { "type": "string", "maxLength": 300 }, "default": [] },
    "artifact_refs": { "type": "array", "items": { "type": "string", "maxLength": 300 }, "default": [] },
    "evidence_refs": { "type": "array", "items": { "type": "string", "maxLength": 300 }, "default": [] },
    "commit_refs": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" }, "default": [] },
    "attached_handoff_refs": { "type": "array", "items": { "type": "string", "maxLength": 120 }, "default": [] },
    "attached_review_gate_refs": { "type": "array", "items": { "type": "string", "maxLength": 120 }, "default": [] },
    "risk": { "type": "string", "enum": ["low", "medium", "high"], "default": "low" },
    "private_data_level": { "type": "string", "enum": ["public", "internal", "private", "secret"], "default": "public" },
    "requires_human_authorization": { "type": "boolean", "default": false },
    "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] },
    "blocked_by": { "type": "array", "items": { "type": "string" }, "default": [] },
    "blocker_cause": { "type": "string", "maxLength": 500 },
    "next_action": { "type": "string", "maxLength": 1000 },
    "unblock_condition": { "type": "string", "maxLength": 1000 },
    "rollback_ref": { "type": "string", "maxLength": 300 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "closed_at": { "type": "string", "format": "date-time" },
    "archived_at": { "type": "string", "format": "date-time" }
  }
}
