# Runtime/secrets
# OpenClaw/OpenClaw-like runtime context can be materialized in the checkout
# during local operator work. These files are private context, not public
# Hermes scaffold artifacts.
/.openclaw/
/AGENTS.md
/HEARTBEAT.md
/IDENTITY.md
/SOUL.md
/TOOLS.md
/USER.md
.env
*.env
!.env.example
/agents/private/
/runtime/
/state/
/secrets/
/backups/
ops/secrets/*
!ops/secrets/.gitkeep
.private-backups/

# Python/node local noise
__pycache__/
*.py[cod]
node_modules/
.venv/
venv/

# macOS/editor
.DS_Store
*.swp
# Honcho local lab source checkout and private env
/honcho-local/honcho-src/
/honcho-local/.env
/honcho-local/honcho.env
/honcho-local/litellm.env

# Local operational evidence and candidate artifacts
/logs/
/ops/candidates/
/build-contexts/
/ops/build-contexts/
/ops/evidence/
/ops/review-packets/
/ops/restore-real-production-*.log
/ops/restore-real-production-*.log.supervisor
/compose.yaml.bak-*

# Host-local snapshots and registered/nested worktrees
/.env.pre-remove-*
/compose.yaml.pre-remove-*
/.worktrees/
/ops/worktrees/
/worktrees/

# Large local integration fixtures require an explicit artifact/LFS review
/test-fixtures/

