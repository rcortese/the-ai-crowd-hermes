# Copy to litellm.env (0600) before container creation. No real secrets here.
# LITELLM_MASTER_KEY is also required in project .env for compose interpolation.
# LITELLM_MASTER_KEY=<generate private value>

# Preferred first lab provider: LiteLLM chatgpt/ via ChatGPT/Codex OAuth.
# Complete device login inside/for the LiteLLM service and persist only in the litellm_token_state volume,
# or place an explicitly approved auth file under the private target path and point CHATGPT_AUTH_FILE at it.
# Do not share Moss's live Codex auth.json with this service unless the operator explicitly accepts the concurrency/refresh risk.
CHATGPT_TOKEN_DIR=/var/lib/litellm/tokens

# Approved fallback only after provider decision/gate.
# DEEPSEEK_API_KEY=<private fallback key>
