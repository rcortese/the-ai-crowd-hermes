# Copy to honcho.env (0600) before container creation. No real secrets here.
LOG_LEVEL=INFO
NAMESPACE=the-ai-crowd-local-honcho
AUTH_USE_AUTH=false

# Honcho sees LiteLLM as an OpenAI-compatible endpoint. LLM_OPENAI_API_KEY is injected by compose from LITELLM_MASTER_KEY.
DERIVER_MODEL_CONFIG__TRANSPORT=openai
DERIVER_MODEL_CONFIG__MODEL=honcho-chat-lab
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=http://litellm:4000/v1
SUMMARY_MODEL_CONFIG__TRANSPORT=openai
SUMMARY_MODEL_CONFIG__MODEL=honcho-chat-lab
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=http://litellm:4000/v1
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL=honcho-chat-lab
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__OVERRIDES__BASE_URL=http://litellm:4000/v1
DIALECTIC_LEVELS__low__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__low__MODEL_CONFIG__MODEL=honcho-chat-lab
DIALECTIC_LEVELS__low__MODEL_CONFIG__OVERRIDES__BASE_URL=http://litellm:4000/v1

# Embeddings are separate from ChatGPT/Codex OAuth. HONCHO_EMBEDDINGS_API_KEY is injected by compose from the private project .env.
EMBED_MESSAGES=true
EMBEDDING_MODEL_CONFIG__TRANSPORT=openai
EMBEDDING_MODEL_CONFIG__MODEL=text-embedding-3-small
EMBEDDING_MODEL_CONFIG__OVERRIDES__API_KEY_ENV=HONCHO_EMBEDDINGS_API_KEY
EMBEDDING_VECTOR_DIMENSIONS=1536

# Safer initial lab posture.
DREAM_ENABLED=false
SUMMARY_ENABLED=true
PEER_CARD_ENABLED=true
CACHE_ENABLED=true
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_MIGRATED=false
TELEMETRY_ENABLED=false
SENTRY_ENABLED=false
METRICS_ENABLED=false
DERIVER_LOG_OBSERVATIONS=false
