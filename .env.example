# Example only; copy to .env and fill per stack. Never commit real .env values.
COMPOSE_PROJECT_NAME=the-ai-crowd
STACK_ENV=prod
TZ=America/Sao_Paulo
HERMES_DASHBOARD_TUI=1
HERMES_UID=99
HERMES_GID=100
HERMES_KANBAN_DISPATCH_OWNER=moss
HERMES_KANBAN_DISPATCH_UNOWNED_BOARDS=false

# BEGIN THE_AI_CROWD_ENV_LAYOUT_MANAGED
