TZ=UTC
HERMES_DASHBOARD_TUI=1
# Run containers as the deployment checkout owner to prevent bind-mounted files
# from becoming owned by root or the image's internal user.
HERMES_UID=1000
HERMES_GID=1000
# Fill per-agent model/API credentials through Hermes dashboard or non-git .env files.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
